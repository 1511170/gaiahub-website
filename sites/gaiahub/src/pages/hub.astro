---
import Layout from '../layouts/Layout.astro';

const locale = 'es';
---

<Layout 
  title="Gaia Hub | El Sistema Nervioso"
  description="La plataforma digital que conecta a miles de actores regenerativos en un solo ecosistema navegable. Ver, Conectar, Coordinar."
  keywords={["Gaia Hub", "plataforma regenerativa", "matchmaking", "directorio", "Gaia GPS", "coordinación", "ecosistema"]}
  schemaType={["WebPage", "Organization"]}
>
  
  <!-- Top Navigation Shell -->
  <nav class="fixed top-0 w-full z-50 bg-[#fefee5]/80 backdrop-blur-xl shadow-[0_40px_60px_-5px_rgba(54,59,16,0.06)]">
    <div class="flex justify-between items-center max-w-[1618px] mx-auto px-6 lg:px-[5.5rem] h-24">
      <a href="/" class="text-3xl font-black text-primary px-6 font-headline tracking-tight">
        Gaia
      </a>
      <div class="hidden md:flex items-center gap-12 font-headline tracking-tight font-bold uppercase text-sm">
        <a class="text-on-surface/70 hover:text-on-surface transition-colors" href="/">Inicio</a>
        <a class="text-primary border-b-2 border-primary pb-1" href="/hub">Hub</a>
        <a class="text-on-surface/70 hover:text-on-surface transition-colors" href="/market">Market</a>
        <a class="text-on-surface/70 hover:text-on-surface transition-colors" href="/commons">Commons</a>
        <div class="relative group">
          <a class="text-on-surface/70 hover:text-on-surface transition-colors flex items-center gap-1" href="/commons">
            Impact
            <span class="material-symbols-outlined text-sm">expand_more</span>
          </a>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white/95 backdrop-blur-xl rounded-xl shadow-xl border border-outline/10 py-2 min-w-[180px]">
              <a class="block px-4 py-2 text-on-surface/70 hover:text-primary hover:bg-surface-container transition-colors text-xs" href="/commons/impact-fund/">Impact Fund</a>
              <a class="block px-4 py-2 text-on-surface/70 hover:text-primary hover:bg-surface-container transition-colors text-xs" href="/commons/impact-hub/">Impact Hub</a>
            </div>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <a href="#comunidad" class="bg-primary text-white px-6 py-3 rounded-full font-headline font-bold text-sm uppercase tracking-wider hover:opacity-90 transition-all scale-95 active:scale-90">
          Únete
        </a>
      </div>
    </div>
  </nav>

  <main class="pt-32">
    <!-- Hero Section -->
    <section class="px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto mb-32">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.618fr] items-center gap-16">
        <div class="order-2 lg:order-1">
          <span class="inline-block px-4 py-1.5 mb-6 bg-secondary-container text-on-secondary-container rounded-full text-xs font-bold uppercase tracking-widest font-label">
            El Sistema Nervioso
          </span>
          <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-black text-on-surface tracking-tighter leading-[0.9] mb-8">
            Donde lo invisible <br/> 
            <span class="text-primary">se vuelve visible</span>
          </h1>
          <p class="text-xl md:text-2xl text-on-surface/60 font-light leading-relaxed mb-10 max-w-xl">
            La plataforma que conecta a miles de actores regenerativos en un solo ecosistema navegable.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#comunidad" class="solar-gradient text-white px-10 py-5 rounded-xl font-headline font-black uppercase text-sm tracking-widest ethereal-shadow hover:translate-y-[-4px] transition-all text-center">
              Entrar al Hub
            </a>
            <a href="#directorio" class="bg-surface-container-high text-on-surface px-10 py-5 rounded-xl font-headline font-bold uppercase text-sm tracking-widest hover:bg-surface-container transition-all text-center">
              Ver Mapa
            </a>
          </div>
        </div>
        <div class="order-1 lg:order-2 relative aspect-[1.618/1]">
          <div class="absolute inset-0 bg-primary/5 rounded-xl overflow-hidden">
            <img 
              alt="Digital Nervous System" 
              class="w-full h-full object-cover opacity-80 mix-blend-multiply" 
              src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
            />
            <div class="absolute inset-0 bg-gradient-to-tr from-background via-transparent to-transparent"></div>
          </div>
          <!-- Floating Data Node -->
          <div class="absolute -bottom-10 -left-10 glass-panel p-8 rounded-xl ethereal-shadow border border-white/40 max-w-xs hidden md:block">
            <span class="material-symbols-outlined text-primary text-4xl mb-4">hub</span>
            <p class="font-headline font-bold text-lg mb-2 uppercase">12.4k Nodos</p>
            <p class="text-sm text-on-surface/60">Proyectos activos regenerando biomas locales en tiempo real.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem: Invisible Landscape -->
    <section class="bg-surface-container py-24 lg:py-32 px-6 lg:px-[5.5rem]">
      <div class="max-w-[1618px] mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-end">
          <div>
            <h2 class="font-headline text-4xl md:text-5xl font-black text-on-surface mb-8 leading-tight">
              Miles de proyectos<br/>
              <span class="text-secondary-dim">todos invisibles entre sí.</span>
            </h2>
            <p class="text-xl leading-relaxed text-on-surface/60">
              Talento disperso. Esfuerzos duplicados. Sinergias perdidas.
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="p-8 bg-white rounded-xl border-l-4 border-error shadow-sm">
              <h4 class="font-headline font-bold uppercase text-xs tracking-widest text-error mb-2">Pérdida</h4>
              <p class="text-on-surface font-medium leading-snug">Talento disperso sin brújula colectiva.</p>
            </div>
            <div class="p-8 bg-white rounded-xl border-l-4 border-error shadow-sm">
              <h4 class="font-headline font-bold uppercase text-xs tracking-widest text-error mb-2">Ineficiencia</h4>
              <p class="text-on-surface font-medium leading-snug">Esfuerzos duplicados por falta de datos.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Solution: 3 Pillars (Bento Grid) -->
    <section class="py-24 lg:py-32 px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto">
      <div class="text-center mb-20">
        <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-black text-on-surface mb-6 uppercase tracking-tighter">
          Ver · Conectar · Coordinar
        </h2>
        <p class="text-lg text-on-surface/60">Tres verbos. Una sola plataforma.</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <!-- Pillar: Ver -->
        <div class="bg-surface-container-high p-10 lg:p-12 rounded-xl flex flex-col justify-between group hover:bg-surface-container transition-all duration-500">
          <div>
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-8 shadow-sm">
              <span class="material-symbols-outlined text-primary text-3xl">map</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl font-black mb-4 uppercase">Ver</h3>
            <p class="text-on-surface/60 leading-relaxed">Mapa vivo de personas, proyectos, comunidades y territorios. Visualiza todo el ecosistema en un solo lugar.</p>
          </div>
          <div class="mt-10">
            <img 
              alt="Mapping Data" 
              class="rounded-lg w-full h-44 object-cover grayscale group-hover:grayscale-0 transition-all" 
              src="https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=2074&auto=format&fit=crop"
            />
          </div>
        </div>

        <!-- Pillar: Conectar -->
        <div class="solar-gradient p-10 lg:p-12 rounded-xl text-white flex flex-col justify-between shadow-xl md:scale-105 z-10">
          <div>
            <div class="w-16 h-16 bg-white/20 backdrop-blur rounded-full flex items-center justify-center mb-8">
              <span class="material-symbols-outlined text-white text-3xl">gesture</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl font-black mb-4 uppercase">Conectar</h3>
            <p class="text-white/90 leading-relaxed">Matchmaking inteligente entre habilidades, necesidades y oportunidades. Genera conexiones que el azar nunca haría.</p>
          </div>
          <div class="mt-10 bg-white/10 p-6 rounded-lg backdrop-blur">
            <div class="flex -space-x-4 mb-4">
              <div class="w-12 h-12 rounded-full border-2 border-primary bg-surface-container-high"></div>
              <div class="w-12 h-12 rounded-full border-2 border-primary bg-surface-container"></div>
              <div class="w-12 h-12 rounded-full border-2 border-primary bg-surface-variant"></div>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest">340 Sinergias detectadas hoy</p>
          </div>
        </div>

        <!-- Pillar: Coordinar -->
        <div class="bg-surface-container-high p-10 lg:p-12 rounded-xl flex flex-col justify-between group hover:bg-surface-container transition-all duration-500">
          <div>
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-8 shadow-sm">
              <span class="material-symbols-outlined text-tertiary text-3xl">groups</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl font-black mb-4 uppercase">Coordinar</h3>
            <p class="text-on-surface/60 leading-relaxed">Herramientas para colaborar a escala sin perder lo humano. De la intención a la acción colectiva.</p>
          </div>
          <div class="mt-10 grid grid-cols-2 gap-2">
            <div class="h-20 bg-white/50 rounded flex items-center justify-center"><span class="material-symbols-outlined opacity-30">task_alt</span></div>
            <div class="h-20 bg-white/50 rounded flex items-center justify-center"><span class="material-symbols-outlined opacity-30">account_balance_wallet</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Focus: Directory & GPS -->
    <section id="directorio" class="py-24 lg:py-32 px-6 lg:px-[5.5rem] bg-surface">
      <div class="max-w-[1618px] mx-auto grid lg:grid-cols-2 gap-16 lg:gap-32 items-center">
        <div class="relative order-2 lg:order-1">
          <div class="aspect-square bg-surface-container rounded-full overflow-hidden ethereal-shadow relative max-w-md mx-auto">
            <img 
              alt="Ecosystem Map" 
              class="w-full h-full object-cover mix-blend-overlay opacity-60" 
              src="https://images.unsplash.com/photo-1577086664693-8949f5b49aeb?q=80&w=2070&auto=format&fit=crop"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-32 h-32 solar-gradient rounded-full blur-3xl opacity-50"></div>
              <span class="material-symbols-outlined text-8xl text-primary/40" style="font-variation-settings: 'FILL' 1;">location_on</span>
            </div>
          </div>
          <div class="absolute top-10 right-10 glass-panel p-6 rounded-xl border border-white/40 shadow-xl max-w-[200px] hidden lg:block">
            <p class="font-headline font-black text-2xl uppercase">98%</p>
            <p class="text-[10px] font-bold uppercase tracking-tighter text-on-surface/60">Precisión en mapeo de impacto</p>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <h3 class="font-headline text-3xl md:text-4xl font-black mb-12 uppercase leading-tight">
            Directorio Global &<br/>Gaia GPS
          </h3>
          <div class="space-y-10">
            <div class="flex gap-6">
              <span class="text-4xl font-headline font-black text-primary/20">01</span>
              <div>
                <h4 class="font-headline font-bold text-xl uppercase mb-2">Todo el ecosistema en un mapa</h4>
                <p class="text-on-surface/60 leading-relaxed">Busca por persona, proyecto, comunidad, territorio, habilidad o necesidad. Desde pequeñas granjas hasta grandes fondos de impacto.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <span class="text-4xl font-headline font-black text-primary/20">02</span>
              <div>
                <h4 class="font-headline font-bold text-xl uppercase mb-2">La inteligencia que conecta</h4>
                <p class="text-on-surface/60 leading-relaxed">Gaia GPS mapea habilidades, necesidades y afinidades. Genera conexiones que el azar nunca haría.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span class="px-3 py-1 bg-surface-container rounded-full text-xs text-on-surface/60">¿Quién necesita qué?</span>
                  <span class="px-3 py-1 bg-surface-container rounded-full text-xs text-on-surface/60">¿Quién puede ayudar?</span>
                  <span class="px-3 py-1 bg-surface-container rounded-full text-xs text-on-surface/60">¿Dónde están las sinergias?</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="comunidad" class="py-32 lg:py-48 px-6 lg:px-[5.5rem] relative overflow-hidden text-center bg-inverse-surface">
      <div class="absolute inset-0 opacity-20">
        <img 
          alt="Nature Network" 
          class="w-full h-full object-cover" 
          src="https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?q=80&w=2069&auto=format&fit=crop"
        />
      </div>
      <div class="relative z-10 max-w-4xl mx-auto">
        <h2 class="font-headline text-4xl md:text-6xl lg:text-7xl font-black text-white mb-8 leading-[0.9] tracking-tighter">
          Sin Hub, somos fragmentos.<br/>
          <span class="text-primary-container">Con Hub, somos red.</span>
        </h2>
        <p class="text-xl text-inverse-on-surface mb-12 max-w-2xl mx-auto font-light">
          Únete a la inteligencia colectiva que está sanando la Tierra.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://t.me/+1x_EVaVp-lEwN2I8" target="_blank" class="solar-gradient text-white px-12 py-6 rounded-full font-headline font-black uppercase text-lg tracking-widest shadow-2xl hover:scale-105 transition-all">
            Únete a la Red
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="w-full py-[5.5rem] bg-surface-container">
    <div class="max-w-[1618px] mx-auto grid grid-cols-1 md:grid-cols-[1.618fr_1fr] gap-12 px-6 lg:px-[5.5rem]">
      <div class="space-y-8">
        <div class="font-headline font-bold text-primary text-2xl tracking-tight">
          Gaia Ecosystem
        </div>
        <p class="font-body text-sm leading-relaxed text-on-surface/60 max-w-sm">
          Infraestructura para una civilización regenerativa. Un ecosistema descentralizado de coordinación planetaria.
        </p>
        <p class="font-body text-sm text-on-surface/40">
          © 2026 Gaia Ecosystem.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-8 font-body text-sm">
        <div class="flex flex-col gap-4">
          <span class="font-bold text-primary uppercase tracking-wider text-xs">Explorar</span>
          <a class="text-on-surface/60 hover:text-primary transition-colors" href="/hub">Gaia Hub</a>
          <a class="text-on-surface/60 hover:text-primary transition-colors" href="/market">Gaia Market</a>
          <a class="text-on-surface/60 hover:text-primary transition-colors" href="/commons">Gaia Commons</a>
        </div>
        <div class="flex flex-col gap-4">
          <span class="font-bold text-primary uppercase tracking-wider text-xs">Comunidad</span>
          <a class="text-on-surface/60 hover:text-primary transition-colors" href="https://t.me/+1x_EVaVp-lEwN2I8" target="_blank">Telegram</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .solar-gradient {
    background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
  }
  .ethereal-shadow {
    box-shadow: 0 40px 60px -5px rgba(54, 59, 16, 0.06);
  }
  .glass-panel {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
  }
</style>
