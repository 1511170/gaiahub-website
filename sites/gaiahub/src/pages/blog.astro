---
import Layout from '../layouts/Layout.astro';
import Navigation from '@site/components/Navigation.astro';
import Footer from '@site/components/Footer.astro';
import { t } from '@site/i18n';
import { getCollection } from 'astro:content';

const locale = 'en';
const i18n = t(locale);

const posts = (await getCollection('blog'))
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Extract unique categories
const categories = [...new Set(posts.map(p => p.data.category))];

// Calculate read time for each post
const postsWithMeta = posts.map(post => {
  const wordCount = post.body.split(/\s+/).filter(w => w.length > 0).length;
  const readTime = Math.max(1, Math.round(wordCount / 200));
  return { ...post, readTime };
});

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout 
  title="Blog | Gaia Ecosystem"
  description="Latest insights from the regenerative ecosystem. Articles on regeneration, governance, economy, and planetary coordination."
  image="/images/hero-banner.webp"
  keywords={["blog", "regeneration", "ecosystem", "governance", "economy"]}
  schemaType={["Blog", "WebSite"]}
>
  <Navigation locale={locale} activePage="blog" />

  <main class="pt-32 pb-20 px-6 lg:px-[5.5rem]">
    <div class="max-w-[1618px] mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-block px-4 py-1.5 rounded-full bg-secondary-container text-on-secondary-container text-xs font-bold tracking-widest uppercase mb-6">
          Regenerative Insights
        </div>
        <h1 class="font-headline text-4xl md:text-6xl lg:text-7xl font-black text-on-surface leading-tight tracking-tighter mb-6">
          Gaia Blog
        </h1>
        <p class="text-xl text-on-surface/70 max-w-2xl mx-auto font-light">
          Stories, research, and insights from the planetary regeneration frontlines.
        </p>
      </div>

      <!-- Search & Filters -->
      <div class="mb-12 space-y-6">
        <!-- Search -->
        <div class="relative max-w-xl mx-auto">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface/40">search</span>
          <input 
            type="text" 
            id="blog-search"
            placeholder="Search articles..."
            class="w-full pl-12 pr-6 py-3.5 rounded-full bg-surface-container-high border border-outline/10 text-on-surface placeholder:text-on-surface/40 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 text-base"
          />
        </div>

        <!-- Category Filters -->
        {categories.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2" id="category-filters">
            <button data-category="all" class="filter-btn px-5 py-2.5 rounded-full text-sm font-bold uppercase tracking-wider transition-all bg-primary text-white shadow-md">
              All
            </button>
            {categories.map(cat => (
              <button data-category={cat} class="filter-btn px-5 py-2.5 rounded-full text-sm font-bold uppercase tracking-wider transition-all bg-surface-container-high text-on-surface/70 hover:bg-surface-container hover:text-on-surface border border-outline/10">
                {cat}
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Posts Grid -->
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-on-surface/50 text-lg">No posts published yet. Check back soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
          {postsWithMeta.map((post) => (
            <a href={`/blog/${post.slug}/`} class="post-card group block bg-surface-container-low rounded-2xl overflow-hidden hover:-translate-y-2 transition-all duration-300 ethereal-shadow border border-outline/5" data-category={post.data.category} data-title={post.data.title.toLowerCase()} data-excerpt={post.data.excerpt.toLowerCase()}>
              <div class="aspect-video bg-surface-container-high overflow-hidden relative">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-6xl text-primary/20">eco</span>
                  </div>
                )}
                <div class="absolute top-3 left-3">
                  <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-on-surface rounded-full text-xs font-bold uppercase tracking-wider shadow-sm">{post.data.category}</span>
                </div>
              </div>
              <div class="p-6 lg:p-8">
                <div class="flex items-center gap-3 text-sm text-on-surface/50 mb-3">
                  <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-base">schedule</span>
                    {formatDate(post.data.date)}
                  </span>
                  <span>·</span>
                  <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-base">menu_book</span>
                    {post.readTime} min
                  </span>
                </div>
                <h2 class="font-headline text-xl font-bold text-on-surface mb-3 group-hover:text-primary transition-colors line-clamp-2">{post.data.title}</h2>
                <p class="text-on-surface/60 text-sm leading-relaxed line-clamp-3 mb-4">{post.data.excerpt}</p>
                <div class="flex items-center gap-2 text-sm font-bold text-primary uppercase tracking-wider group-hover:gap-4 transition-all">
                  Read more <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- Empty state (hidden by default) -->
      <div id="no-results" class="hidden text-center py-20">
        <span class="material-symbols-outlined text-6xl text-on-surface/20 mb-4 block">search_off</span>
        <p class="text-on-surface/50 text-lg">No articles match your search.</p>
        <button onclick="resetFilters()" class="mt-4 px-6 py-2.5 rounded-full bg-primary text-white font-headline font-bold text-sm hover:opacity-90 transition-all">
          Clear filters
        </button>
      </div>
    </div>
  </main>

  <Footer locale={locale} />
</Layout>

<script is:inline>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.post-card');
  const searchInput = document.getElementById('blog-search');
  const noResults = document.getElementById('no-results');
  const grid = document.getElementById('posts-grid');
  let activeCategory = 'all';

  function updateVisibility() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    cards.forEach(card => {
      const cat = card.dataset.category;
      const title = card.dataset.title;
      const excerpt = card.dataset.excerpt;
      const matchesCategory = activeCategory === 'all' || cat === activeCategory;
      const matchesSearch = !query || title.includes(query) || excerpt.includes(query);
      const visible = matchesCategory && matchesSearch;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    if (visibleCount === 0) {
      grid.classList.add('hidden');
      noResults.classList.remove('hidden');
    } else {
      grid.classList.remove('hidden');
      noResults.classList.add('hidden');
    }
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.category;
      filterBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-white', 'shadow-md');
        b.classList.add('bg-surface-container-high', 'text-on-surface/70', 'border', 'border-outline/10');
      });
      btn.classList.remove('bg-surface-container-high', 'text-on-surface/70', 'border', 'border-outline/10');
      btn.classList.add('bg-primary', 'text-white', 'shadow-md');
      updateVisibility();
    });
  });

  searchInput.addEventListener('input', updateVisibility);

  function resetFilters() {
    activeCategory = 'all';
    searchInput.value = '';
    filterBtns.forEach(b => {
      if (b.dataset.category === 'all') {
        b.classList.remove('bg-surface-container-high', 'text-on-surface/70', 'border', 'border-outline/10');
        b.classList.add('bg-primary', 'text-white', 'shadow-md');
      } else {
        b.classList.remove('bg-primary', 'text-white', 'shadow-md');
        b.classList.add('bg-surface-container-high', 'text-on-surface/70', 'border', 'border-outline/10');
      }
    });
    updateVisibility();
  }
</script>

<style>
  .ethereal-shadow {
    box-shadow: 0 40px 60px -5px rgba(54, 59, 16, 0.06);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
