---
import Layout from '../../layouts/Layout.astro';
import Navigation from '@site/components/Navigation.astro';
import Footer from '@site/components/Footer.astro';
import { t } from '@site/i18n';

const locale = 'es';
const i18n = t(locale);
---

<Layout 
  title={i18n.hub.meta_title}
  description={i18n.hub.meta_description}
  keywords={["Gaia Hub", "plataforma regenerativa", "matchmaking", "directorio", "Gaia GPS", "coordinación", "ecosistema"]}
  schemaType={["WebPage", "Organization"]}
>
  
  <Navigation locale={locale} activePage="hub" />

  <main class="pt-32">
    <!-- Hero Section -->
    <section class="px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto mb-32">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.618fr] items-center gap-16">
        <div class="order-2 lg:order-1">
          <span class="inline-block px-4 py-1.5 mb-6 bg-secondary-container text-on-secondary-container rounded-full text-xs font-bold uppercase tracking-widest font-label">
            {i18n.hub.hero_badge}
          </span>
          <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-black text-on-surface tracking-tighter leading-[0.9] mb-8">
            {i18n.hub.hero_title}
          </h1>
          <p class="text-xl md:text-2xl text-on-surface/60 font-light leading-relaxed mb-10 max-w-xl">
            {i18n.hub.hero_subtitle}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/es/confederation/" class="solar-gradient text-white px-10 py-5 rounded-xl font-headline font-black uppercase text-sm tracking-widest ethereal-shadow hover:translate-y-[-4px] transition-all text-center">
              {i18n.hub.cta_enter}
            </a>
            <a href="#directorio" class="bg-surface-container-high text-on-surface px-10 py-5 rounded-xl font-headline font-bold uppercase text-sm tracking-widest hover:bg-surface-container transition-all text-center">
              {i18n.hub.cta_map}
            </a>
          </div>
        </div>
        <div class="order-1 lg:order-2 relative aspect-[1.618/1]">
          <div class="absolute inset-0 bg-primary/5 rounded-xl overflow-hidden">
            <img 
              alt="Digital Nervous System" 
              class="w-full h-full object-cover opacity-80 mix-blend-multiply" 
              src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
            />
            <div class="absolute inset-0 bg-gradient-to-tr from-background via-transparent to-transparent"></div>
          </div>
          <!-- Floating Data Node -->
          <div class="absolute -bottom-10 -left-10 glass-panel p-8 rounded-xl ethereal-shadow border border-white/40 max-w-xs hidden md:block">
            <span class="material-symbols-outlined text-primary text-4xl mb-4">hub</span>
            <p class="text-sm text-on-surface/60">{i18n.hub.stat_nodes_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- The Problem: Invisible Landscape -->
    <section class="bg-surface-container py-24 lg:py-32 px-6 lg:px-[5.5rem]">
      <div class="max-w-[1618px] mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-end">
          <div>
            <h2 class="font-headline text-4xl md:text-5xl font-black text-on-surface mb-8 leading-tight" set:html={i18n.hub.problem_title}></h2>
            <p class="text-xl leading-relaxed text-on-surface/60">
              {i18n.hub.problem_subtitle}
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="p-8 bg-white rounded-xl border-l-4 border-error shadow-sm">
              <h4 class="font-headline font-bold uppercase text-xs tracking-widest text-error mb-2">{i18n.hub.problem_loss}</h4>
              <p class="text-on-surface font-medium leading-snug">{i18n.hub.problem_loss_desc}</p>
            </div>
            <div class="p-8 bg-white rounded-xl border-l-4 border-error shadow-sm">
              <h4 class="font-headline font-bold uppercase text-xs tracking-widest text-error mb-2">{i18n.hub.problem_inefficiency}</h4>
              <p class="text-on-surface font-medium leading-snug">{i18n.hub.problem_inefficiency_desc}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Solution: 3 Pillars (Bento Grid) -->
    <section class="py-24 lg:py-32 px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto">
      <div class="text-center mb-20">
        <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-black text-on-surface mb-6 uppercase tracking-tighter">
          {i18n.hub.solution_title}
        </h2>
        <p class="text-lg text-on-surface/60">{i18n.hub.solution_subtitle}</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <!-- Pillar: Ver -->
        <div class="bg-surface-container-high p-10 lg:p-12 rounded-xl flex flex-col justify-between group hover:bg-surface-container transition-all duration-500">
          <div>
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-8 shadow-sm">
              <span class="material-symbols-outlined text-primary text-3xl">map</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl font-black mb-4 uppercase">{i18n.hub.see_title}</h3>
            <p class="text-on-surface/60 leading-relaxed whitespace-pre-line">{i18n.hub.see_desc}</p>
          </div>
          <div class="mt-10">
            <img 
              alt="Mapping Data" 
              class="rounded-lg w-full h-44 object-cover grayscale group-hover:grayscale-0 transition-all" 
              src="https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=2074&auto=format&fit=crop"
            />
          </div>
        </div>

        <!-- Pillar: Conectar -->
        <div class="solar-gradient p-10 lg:p-12 rounded-xl text-white flex flex-col justify-between shadow-xl md:scale-105 z-10">
          <div>
            <div class="w-16 h-16 bg-white/20 backdrop-blur rounded-full flex items-center justify-center mb-8">
              <span class="material-symbols-outlined text-white text-3xl">gesture</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl font-black mb-4 uppercase">{i18n.hub.connect_title}</h3>
            <p class="text-white/90 leading-relaxed whitespace-pre-line">{i18n.hub.connect_desc}</p>
          </div>
          <div class="mt-10 bg-white/10 p-6 rounded-lg backdrop-blur">
            <div class="flex -space-x-4 mb-4">
              <div class="w-12 h-12 rounded-full border-2 border-primary bg-surface-container-high"></div>
              <div class="w-12 h-12 rounded-full border-2 border-primary bg-surface-container"></div>
              <div class="w-12 h-12 rounded-full border-2 border-primary bg-surface-variant"></div>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest">{i18n.hub.connect_stats}</p>
          </div>
        </div>

        <!-- Pillar: Coordinar -->
        <div class="bg-surface-container-high p-10 lg:p-12 rounded-xl flex flex-col justify-between group hover:bg-surface-container transition-all duration-500">
          <div>
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-8 shadow-sm">
              <span class="material-symbols-outlined text-tertiary text-3xl">groups</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl font-black mb-4 uppercase">{i18n.hub.coordinate_title}</h3>
            <p class="text-on-surface/60 leading-relaxed whitespace-pre-line">{i18n.hub.coordinate_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Focus: Directory & GPS -->
    <section id="directorio" class="py-24 lg:py-32 px-6 lg:px-[5.5rem] bg-surface">
      <div class="max-w-[1618px] mx-auto grid lg:grid-cols-2 gap-16 lg:gap-32 items-center">
        <div class="relative order-2 lg:order-1">
          <div class="aspect-square bg-surface-container rounded-full overflow-hidden ethereal-shadow relative max-w-md mx-auto">
            <img 
              alt="Ecosystem Map" 
              class="w-full h-full object-cover mix-blend-overlay opacity-60" 
              src="https://images.unsplash.com/photo-1577086664693-8949f5b49aeb?q=80&w=2070&auto=format&fit=crop"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-32 h-32 solar-gradient rounded-full blur-3xl opacity-50"></div>
              <span class="material-symbols-outlined text-8xl text-primary/40" style="font-variation-settings: 'FILL' 1;">location_on</span>
            </div>
          </div>
          <div class="absolute top-10 right-10 glass-panel p-6 rounded-xl border border-white/40 shadow-xl max-w-[200px] hidden lg:block">
            <p class="font-headline font-black text-2xl uppercase">{i18n.hub.stat_precision_value}</p>
            <p class="text-[10px] font-bold uppercase tracking-tighter text-on-surface/60">{i18n.hub.stat_precision_desc}</p>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <h3 class="font-headline text-3xl md:text-4xl font-black mb-12 uppercase leading-tight">
            {i18n.hub.directory_title}
          </h3>
          <div class="space-y-10">
            <div class="flex gap-6">
              <span class="text-4xl font-headline font-black text-primary/20">01</span>
              <div>
                <h4 class="font-headline font-bold text-xl uppercase mb-2">{i18n.hub.directory_feature1}</h4>
                <p class="text-on-surface/60 leading-relaxed">{i18n.hub.directory_feature1_desc}</p>
              </div>
            </div>
            <div class="flex gap-6">
              <span class="text-4xl font-headline font-black text-primary/20">02</span>
              <div>
                <h4 class="font-headline font-bold text-xl uppercase mb-2">{i18n.hub.directory_feature2}</h4>
                <p class="text-on-surface/60 leading-relaxed">{i18n.hub.directory_feature2_desc}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span class="px-3 py-1 bg-surface-container rounded-full text-xs text-on-surface/60">{i18n.hub.directory_tag1}</span>
                  <span class="px-3 py-1 bg-surface-container rounded-full text-xs text-on-surface/60">{i18n.hub.directory_tag2}</span>
                  <span class="px-3 py-1 bg-surface-container rounded-full text-xs text-on-surface/60">{i18n.hub.directory_tag3}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="comunidad" class="py-32 lg:py-48 px-6 lg:px-[5.5rem] relative overflow-hidden text-center bg-inverse-surface">
      <div class="absolute inset-0 opacity-20">
        <img 
          alt="Nature Network" 
          class="w-full h-full object-cover" 
          src="https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?q=80&w=2069&auto=format&fit=crop"
        />
      </div>
      <div class="relative z-10 max-w-4xl mx-auto">
        <h2 class="font-headline text-4xl md:text-6xl lg:text-7xl font-black text-white mb-8 leading-[0.9] tracking-tighter">
          {i18n.hub.cta_final_title}
        </h2>
        <p class="text-xl text-inverse-on-surface mb-12 max-w-2xl mx-auto font-light">
          {i18n.hub.cta_final_subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://whatsapp.com/channel/0029VbCY4kLIiRozv7gGVN3L" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-4 rounded-full font-headline font-bold text-base tracking-wider shadow-lg hover:scale-105 transition-all inline-flex items-center gap-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            WhatsApp
          </a>
          <a href="https://t.me/+1x_EVaVp-lEwN2I8" target="_blank" rel="noopener noreferrer" class="bg-[#0088cc] text-white px-8 py-4 rounded-full font-headline font-bold text-base tracking-wider shadow-lg hover:scale-105 transition-all inline-flex items-center gap-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Telegram
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Layout>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .solar-gradient {
    background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
  }
  .ethereal-shadow {
    box-shadow: 0 40px 60px -5px rgba(54, 59, 16, 0.06);
  }
  .glass-panel {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
  }
</style>
