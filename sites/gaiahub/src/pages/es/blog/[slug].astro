---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '@site/components/Navigation.astro';
import Footer from '@site/components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(p => p.data.published)
    .map(post => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Calculate read time
const wordCount = post.body.split(/\s+/).filter(w => w.length > 0).length;
const readTime = Math.max(1, Math.round(wordCount / 200));

// Extract TOC from post body
const headingMatches = [...post.body.matchAll(/^#{2,3}\s+(.+)$/gm)];
const toc = headingMatches.map(m => {
  const level = m[0].startsWith('###') ? 3 : 2;
  const text = m[1].trim();
  const id = text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
  return { level, text, id };
});

// Get all posts for prev/next navigation
const allPosts = (await getCollection('blog'))
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentIndex = allPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

// Related posts (same category, exclude current)
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);

const shareUrl = `https://gaiahub.co/es/blog/${post.slug}/`;
const shareText = encodeURIComponent(post.data.title);
---

<Layout 
  title={`${post.data.title} | Blog Gaia`}
  description={post.data.excerpt}
  type="article"
  publishedTime={post.data.date.toISOString()}
  author={post.data.author}
  image={post.data.image}
  keywords={post.data.tags}
  schemaType={["BlogPosting", "Article"]}
>
  <Navigation locale="es" activePage="blog" />

  <!-- Hero Image -->
  {post.data.image && (
    <div class="relative w-full h-[40vh] min-h-[280px] max-h-[420px] overflow-hidden">
      <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent"></div>
    </div>
  )}

  <main class="pb-20 px-6 lg:px-[5.5rem]">
    <div class="max-w-[1618px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 lg:gap-16">
        
        <!-- Main Content -->
        <article class={post.data.image ? '-mt-24 relative z-10' : 'pt-32'}>
          <!-- Header Card -->
          <div class="bg-surface-container-low rounded-2xl p-8 md:p-10 shadow-lg border border-outline/5 mb-10">
            <div class="flex flex-wrap items-center gap-3 text-sm text-on-surface/50 mb-4">
              <span class="px-3 py-1 bg-primary-container text-on-primary-container rounded-full text-xs font-bold uppercase tracking-wider">{post.data.category}</span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-base">schedule</span>
                {formatDate(post.data.date)}
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-base">menu_book</span>
                {readTime} min de lectura
              </span>
            </div>
            <h1 class="font-headline text-3xl md:text-4xl lg:text-5xl font-black text-on-surface leading-tight tracking-tighter mb-4">
              {post.data.title}
            </h1>
            <p class="text-lg md:text-xl text-on-surface/70 leading-relaxed">{post.data.excerpt}</p>
          </div>

          <!-- Author -->
          <div class="flex items-center gap-4 pb-8 mb-8 border-b border-outline/20">
            <div class="w-14 h-14 bg-primary-container rounded-full flex items-center justify-center text-xl font-bold text-on-primary-container">
              {post.data.author.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="font-headline font-bold text-on-surface">{post.data.author}</div>
              <div class="text-on-surface/50 text-sm">Contribuidor del Ecosistema Gaia</div>
            </div>
          </div>

          <!-- Content -->
          <div class="prose prose-lg max-w-none">
            <Content />
          </div>

          <!-- Tags -->
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="pt-8 mt-12 border-t border-outline/20">
              <p class="text-sm font-bold text-on-surface/50 uppercase tracking-wider mb-3">Temas</p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map(tag => (
                  <span class="px-4 py-2 bg-surface-container-high text-on-surface/70 rounded-full text-sm font-medium">{tag}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Share -->
          <div class="pt-8 mt-8 border-t border-outline/20">
            <p class="text-sm font-bold text-on-surface/50 uppercase tracking-wider mb-4">Compartir artículo</p>
            <div class="flex flex-wrap gap-3">
              <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-container-high text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors text-sm font-medium">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Compartir en X
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-container-high text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors text-sm font-medium">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + shareUrl)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-container-high text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors text-sm font-medium">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp
              </a>
              <button onclick="navigator.clipboard.writeText('{shareUrl}'); this.innerHTML='<span class=\'material-symbols-outlined text-base\'>check</span> ¡Copiado!'; setTimeout(() => this.innerHTML='<span class=\'material-symbols-outlined text-base\'>content_copy</span> Copiar enlace', 2000)" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-surface-container-high text-on-surface hover:bg-primary-container hover:text-on-primary-container transition-colors text-sm font-medium cursor-pointer">
                <span class="material-symbols-outlined text-base">content_copy</span>
                Copiar enlace
              </button>
            </div>
          </div>

          <!-- Prev / Next Navigation -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-8 mt-8 border-t border-outline/20">
            {prevPost && (
              <a href={`/es/blog/${prevPost.slug}/`} class="group p-5 rounded-xl bg-surface-container-low hover:bg-surface-container transition-colors border border-outline/5">
                <span class="text-xs font-bold text-on-surface/40 uppercase tracking-wider mb-2 block">Anterior</span>
                <span class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-2">{prevPost.data.title}</span>
              </a>
            )}
            {nextPost && (
              <a href={`/es/blog/${nextPost.slug}/`} class={`group p-5 rounded-xl bg-surface-container-low hover:bg-surface-container transition-colors border border-outline/5 ${!prevPost ? 'md:col-start-2' : ''}`}>
                <span class="text-xs font-bold text-on-surface/40 uppercase tracking-wider mb-2 block text-right">Siguiente</span>
                <span class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-2 text-right">{nextPost.data.title}</span>
              </a>
            )}
          </div>

          <!-- Back -->
          <div class="mt-12">
            <a href="/es/blog/" class="inline-flex items-center gap-2 font-headline font-bold text-primary hover:gap-4 transition-all uppercase tracking-wider text-sm">
              <span class="material-symbols-outlined">arrow_back</span> Volver al Blog
            </a>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="lg:pt-32 space-y-8">
          {/* TOC */}
          {toc.length > 0 && (
            <div class="bg-surface-container-low rounded-2xl p-6 border border-outline/5 sticky top-32">
              <h3 class="font-headline font-bold text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">format_list_bulleted</span>
                Contenido
              </h3>
              <ul class="space-y-2">
                {toc.map(item => (
                  <li class={`${item.level === 3 ? 'ml-3' : ''}`}>
                    <a href={`#${item.id}`} class={`block py-1 px-2 text-sm rounded-md transition-colors ${item.level === 2 ? 'font-semibold text-on-surface/80 hover:text-primary hover:bg-primary-container/20' : 'text-on-surface/60 hover:text-primary hover:bg-primary-container/10'}`}>
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Related Posts */}
          {relatedPosts.length > 0 && (
            <div class="bg-surface-container-low rounded-2xl p-6 border border-outline/5">
              <h3 class="font-headline font-bold text-on-surface mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">auto_awesome</span>
                Relacionados
              </h3>
              <div class="space-y-4">
                {relatedPosts.map(rp => (
                  <a href={`/es/blog/${rp.slug}/`} class="group block">
                    {rp.data.image && (
                      <div class="aspect-video rounded-lg overflow-hidden mb-2">
                        <img src={rp.data.image} alt={rp.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                      </div>
                    )}
                    <span class="text-xs font-bold text-primary uppercase tracking-wider">{rp.data.category}</span>
                    <h4 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors text-sm line-clamp-2">{rp.data.title}</h4>
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </main>

  <Footer locale="es" />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prose img {
    max-height: 420px;
    width: 100%;
    object-fit: cover;
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }
  @media (max-width: 768px) {
    .prose img {
      max-height: 280px;
    }
  }
</style>
