---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../../config/site.config.ts';

// Importar componentes de skills
import { SEOHead, SchemaOrg } from '../../../../skills/community/seo-ai-citations/index.ts';
import { TestimonialsGrid } from '../../../../skills/community/testimonials/index.ts';
import { ContactForm } from '../../../../skills/community/contact-form/index.ts';

// Testimonios del ecosistema
const testimonials = [
  {
    name: "María González",
    role: "Coordinadora Bioregional",
    company: "EcoVillage Costa Rica",
    content: "Gaia Hub transformó cómo nuestra comunidad se conecta con el mundo. De estar aislados, ahora somos nodos activos de un ecosistema global regenerativo.",
    rating: 5,
    image: "/images/testimonial-1.jpg"
  },
  {
    name: "Carlos Rodríguez",
    role: "Director de Impacto",
    company: "Regen Foundation",
    content: "El sistema de matchmaking de Gaia GPS nos conectó con aliados estratégicos que ni sabíamos que existían. La inteligencia del ecosistema es real.",
    rating: 5,
    image: "/images/testimonial-2.jpg"
  },
  {
    name: "Ana Martínez",
    role: "Emprendedora Regenerativa",
    company: "Semillas del Futuro",
    content: "En Gaia Market encontramos no solo clientes, sino una comunidad que valora verdaderamente lo regenerativo. Las ventas crecieron 300% en 6 meses.",
    rating: 5,
    image: "/images/testimonial-3.jpg"
  }
];

// Métricas del ecosistema
const metrics = [
  { value: "150+", label: "Bioregiones Activas", icon: "public" },
  { value: "2.4K", label: "Proyectos Regenerativos", icon: "eco" },
  { value: "$12M", label: "Capital Desplegado", icon: "account_balance" },
  { value: "45K", label: "Miembros del Ecosistema", icon: "diversity_3" }
];

// Servicios/Core Functions de Gaia Hub
const coreFunctions = [
  {
    icon: "visibility",
    title: "Ecosystem Visibility",
    description: "Make the ecosystem visible through a living directory and global map of people, projects, communities, and territories."
  },
  {
    icon: "hub",
    title: "Intelligent Connections",
    description: "Enable intelligent connections via Gaia GPS - mapping skills, needs, capacities, affinities, and bioregions."
  },
  {
    icon: "groups",
    title: "Coordination Infrastructure",
    description: "Coordinate collaboration across distributed actors functioning as a living regenerative network."
  },
  {
    icon: "track_changes",
    title: "Contribution Tracking",
    description: "Track contributions and reputation through transparent on-chain and off-chain mechanisms."
  },
  {
    icon: "account_balance",
    title: "Governance Support",
    description: "Support decision-making and governance through polycentric councils, DAOs, and consensus tools."
  },
  {
    icon: "auto_awesome",
    title: "Evolution & Adaptation",
    description: "Evolve as a platform that learns, adapts, and grows with its community of stewards."
  }
];
---

+<head>
  <SEOHead 
    title="Gaia Hub | Digital Coordination Platform for Regenerative Ecosystems"
    description="Gaia Hub is the digital operating system of the Gaia Ecosystem. A meta-platform for network coordination, matchmaking, and regenerative collaboration."
    keywords={["regenerative economy", "Gaia Hub", "commons", "bioregions", "impact fund", "regenerative marketplace", "coordination platform"]}
    ogImage="/og-image.jpg"
    canonicalUrl="https://gaiahub.co"
  />
  <SchemaOrg type={["Organization", "WebSite"]} />
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  
  <style is:global>
    :root {
      --color-primary: #776300;
      --color-primary-container: #ffd709;
      --color-on-primary-container: #5b4b00;
      --color-secondary: #00743a;
      --color-secondary-container: #86fea7;
      --color-on-secondary-container: #00612f;
      --color-tertiary: #8e00fd;
      --color-tertiary-container: #d0a7ff;
      --color-on-tertiary-container: #500092;
      --color-background: #fefee5;
      --color-on-surface: #363b10;
      --color-on-surface-variant: #626838;
      --color-surface: #fefee5;
      --color-surface-container: #f4f7ce;
      --color-surface-container-low: #fafcda;
      --color-surface-container-high: #eef2bf;
      --color-surface-container-highest: #e7edb1;
      --color-outline: #7f8452;
      --color-outline-variant: #b8be86;
      --color-error: #b23d21;
    }
    
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    
    .glass-panel {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
    
    .solar-gradient {
      background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
    }
    
    .ethereal-shadow {
      box-shadow: 0 40px 60px -20px rgba(54, 59, 16, 0.06);
    }
    
    .font-headline {
      font-family: 'Epilogue', sans-serif;
    }
    
    .font-body {
      font-family: 'Manrope', sans-serif;
    }
  </style>
</head>

<Layout title="Gaia Hub | Digital Coordination Platform">
  <main class="min-h-screen" style="background-color: #fefee5; color: #363b10;">
    
    <!-- Top Navigation Shell -->
    <nav class="sticky top-0 z-50 w-full px-6 lg:px-12 py-6 max-w-[1920px] mx-auto flex justify-between items-center backdrop-blur-xl" style="background: rgba(254, 254, 229, 0.8); box-shadow: 0 20px 40px -15px rgba(54, 59, 16, 0.05);">
      <div class="text-2xl font-black tracking-tighter font-headline" style="color: #776300;">Gaia Hub</div>
      <div class="hidden md:flex items-center gap-10">
        <a class="font-headline tracking-tight font-bold uppercase text-sm transition-colors hover:text-[#363b10]" style="color: rgba(54, 59, 16, 0.6);" href="#intelligence">Intelligence</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm transition-colors hover:text-[#363b10]" style="color: rgba(54, 59, 16, 0.6);" href="#market">Market</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm transition-colors hover:text-[#363b10]" style="color: rgba(54, 59, 16, 0.6);" href="#commons">Commons</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm transition-colors hover:text-[#363b10]" style="color: rgba(54, 59, 16, 0.6);" href="#capital">Capital</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm transition-colors hover:text-[#363b10]" style="color: rgba(54, 59, 16, 0.6);" href="#incubation">Incubation</a>
      </div>
      <div class="flex items-center gap-4 lg:gap-6">
        <button class="material-symbols-outlined p-2 rounded-full transition-all hover:bg-[#ffd709]/10" style="color: #776300;">search</button>
        <button class="hidden sm:block px-6 lg:px-8 py-3 rounded-full text-white font-headline text-xs tracking-widest uppercase hover:scale-[1.02] active:scale-95 transition-all ethereal-shadow solar-gradient">Connect Soul</button>
        <button class="sm:hidden material-symbols-outlined p-2 rounded-full" style="color: #776300;">menu</button>
      </div>
    </nav>

    <!-- Hero Section: The Conduit of Light -->
    <section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-20 lg:pt-32 pb-16 px-6 overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
        <div class="absolute top-[-10%] right-[-5%] w-[400px] h-[400px] lg:w-[600px] lg:h-[600px] rounded-full blur-[120px]" style="background: #ffd709;"></div>
        <div class="absolute bottom-[0%] left-[-10%] w-[300px] h-[300px] lg:w-[500px] lg:h-[500px] rounded-full blur-[100px]" style="background: #86fea7;"></div>
      </div>
      
      <div class="relative z-10 text-center max-w-5xl px-4">
        <span class="inline-block px-6 py-2 rounded-full font-semibold text-sm tracking-wide mb-8 font-label" style="background: rgba(134, 254, 167, 0.4); color: #00612f;">
          Ethereal Conduit v2.0
        </span>
        
        <h1 class="font-headline text-4xl sm:text-5xl md:text-7xl lg:text-8xl xl:text-9xl font-black tracking-tighter leading-[0.9] mb-8 lg:mb-12" style="color: #776300;">
          The Digital <br/>
          <span class="text-transparent bg-clip-text solar-gradient">Nervous System</span>
        </h1>
        
        <p class="font-body text-lg sm:text-xl md:text-2xl mb-10 lg:mb-16 max-w-2xl mx-auto leading-relaxed" style="color: rgba(54, 59, 16, 0.7);">
          Harmonizing human intelligence with planetary vitality through an interconnected web of capital, commons, and market flows.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8">
          <a href="#ecosystem" class="solar-gradient text-white px-10 lg:px-12 py-4 lg:py-5 rounded-full font-headline text-sm tracking-widest uppercase shadow-xl hover:scale-105 transition-all w-full sm:w-auto text-center">
            Enter the Portal
          </a>
          <a href="#triad" class="group flex items-center justify-center gap-3 font-headline text-sm tracking-widest uppercase" style="color: #776300;">
            Explore Governance <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
          </a>
        </div>
      </div>
      
      <!-- Asymmetric Visual Element -->
      <div class="relative mt-16 lg:mt-32 w-full max-w-7xl px-4 sm:px-6">
        <div class="aspect-[21/9] rounded-xl overflow-hidden ethereal-shadow relative">
          <img 
            alt="Earth from space" 
            class="w-full h-full object-cover"
            src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#fefee5]/80 to-transparent"></div>
          <div class="absolute bottom-6 left-6 lg:bottom-12 lg:left-12">
            <p class="font-headline text-white/90 text-lg lg:text-2xl font-bold drop-shadow-lg">A Living Regenerative Organism</p>
            <p class="font-body text-white/70 text-sm lg:text-base drop-shadow-md">Coordinating 150+ bioregions worldwide</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-12">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          {metrics.map((metric) => (
            <div class="text-center p-6 lg:p-8 rounded-2xl ethereal-shadow" style="background: white;">
              <div class="w-12 h-12 lg:w-16 lg:h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background: rgba(255, 215, 9, 0.2);">
                <span class="material-symbols-outlined text-2xl lg:text-3xl" style="color: #776300;">{metric.icon}</span>
              </div>
              <div class="font-headline text-3xl lg:text-5xl font-black tracking-tighter mb-2" style="color: #776300;">{metric.value}</div>
              <div class="font-body text-xs lg:text-sm uppercase tracking-widest" style="color: rgba(54, 59, 16, 0.6);">{metric.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Triad of Life Section -->
    <section id="triad" class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12 max-w-[1920px] mx-auto">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-12 lg:mb-24 gap-6 lg:gap-8">
        <div class="max-w-xl">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4" style="background: rgba(119, 99, 0, 0.1); color: #776300;">The Gaia Triad</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4 lg:mb-6" style="color: #363b10;">The Triad of Life</h2>
          <p class="font-body text-base lg:text-lg" style="color: rgba(54, 59, 16, 0.6);">Our ecosystem functions as a biological entity, utilizing three core systems to process value, information, and wisdom.</p>
        </div>
        <div class="flex gap-2 lg:gap-4">
          <div class="w-12 lg:w-16 h-1 rounded-full" style="background: #776300;"></div>
          <div class="w-6 lg:w-8 h-1 rounded-full" style="background: rgba(119, 99, 0, 0.2);"></div>
          <div class="w-6 lg:w-8 h-1 rounded-full" style="background: rgba(119, 99, 0, 0.2);"></div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-12">
        <!-- Card 1: Gaia Hub (Nervous System) -->
        <div class="group relative rounded-xl lg:rounded-2xl p-6 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between" style="background: white;">
          <div class="absolute top-0 right-0 p-6 lg:p-8">
            <span class="material-symbols-outlined text-3xl lg:text-4xl transition-colors" style="color: rgba(119, 99, 0, 0.2);" class="group-hover:text-[#776300]">hub</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full flex items-center justify-center mb-6 lg:mb-10 group-hover:scale-110 transition-transform" style="background: rgba(255, 215, 9, 0.2);">
              <span class="material-symbols-outlined text-2xl lg:text-3xl" style="color: #776300;">network_intelligence</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl mb-3 lg:mb-4" style="color: #363b10;">Gaia Hub</h3>
            <div class="inline-block px-3 lg:px-4 py-1 rounded-full font-bold text-[10px] tracking-widest uppercase mb-4 lg:mb-6" style="background: rgba(134, 254, 167, 0.3); color: #00612f;">The Nervous System</div>
            <p class="font-body text-sm lg:text-base leading-relaxed mb-6 lg:mb-8" style="color: rgba(54, 59, 16, 0.6);">The digital coordination platform that makes the ecosystem visible, enables intelligent connections, and coordinates collaboration across distributed actors.</p>
          </div>
          <ul class="space-y-2 font-body text-xs lg:text-sm mb-6" style="color: rgba(54, 59, 16, 0.7);">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #776300;">check</span>Directory & Global Map</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #776300;">check</span>Gaia GPS Matchmaking</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #776300;">check</span>Contribution Tracking</li>
          </ul>
          <a href="#hub" class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase font-bold" style="color: #776300;">
            Synchronize <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </a>
        </div>

        <!-- Card 2: Gaia Market (Circulatory) -->
        <div id="market" class="group relative rounded-xl lg:rounded-2xl p-6 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between" style="background: rgba(244, 247, 206, 0.5); border: 1px solid rgba(119, 99, 0, 0.05);">
          <div class="absolute top-0 right-0 p-6 lg:p-8">
            <span class="material-symbols-outlined text-3xl lg:text-4xl transition-colors" style="color: rgba(119, 99, 0, 0.2);" class="group-hover:text-[#776300]">currency_exchange</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full flex items-center justify-center mb-6 lg:mb-10 group-hover:scale-110 transition-transform" style="background: rgba(119, 99, 0, 0.1);">
              <span class="material-symbols-outlined text-2xl lg:text-3xl" style="color: #776300;">storefront</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl mb-3 lg:mb-4" style="color: #363b10;">Gaia Market</h3>
            <div class="inline-block px-3 lg:px-4 py-1 rounded-full font-bold text-[10px] tracking-widest uppercase mb-4 lg:mb-6" style="background: rgba(255, 215, 9, 0.3); color: #5b4b00;">Circulatory System</div>
            <p class="font-body text-sm lg:text-base leading-relaxed mb-6 lg:mb-8" style="color: rgba(54, 59, 16, 0.6);">The regenerative marketplace where value is exchanged in alignment with regenerative principles - products, services, experiences, and knowledge.</p>
          </div>
          <ul class="space-y-2 font-body text-xs lg:text-sm mb-6" style="color: rgba(54, 59, 16, 0.7);">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #776300;">check</span>Regenerative Products</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #776300;">check</span>Services & Experiences</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #776300;">check</span>Knowledge & Courses</li>
          </ul>
          <a href="#marketplace" class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase font-bold" style="color: #776300;">
            Exchange <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </a>
        </div>

        <!-- Card 3: The Commons (Soul) -->
        <div id="commons" class="group relative rounded-xl lg:rounded-2xl p-6 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between" style="background: rgba(238, 242, 191, 0.6);">
          <div class="absolute top-0 right-0 p-6 lg:p-8">
            <span class="material-symbols-outlined text-3xl lg:text-4xl transition-colors" style="color: rgba(142, 0, 253, 0.2);" class="group-hover:text-[#8e00fd]">diversity_3</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full flex items-center justify-center mb-6 lg:mb-10 group-hover:scale-110 transition-transform" style="background: rgba(208, 167, 255, 0.3);">
              <span class="material-symbols-outlined text-2xl lg:text-3xl" style="color: #8e00fd;">account_balance</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl mb-3 lg:mb-4" style="color: #363b10;">Gaia Commons</h3>
            <div class="inline-block px-3 lg:px-4 py-1 rounded-full font-bold text-[10px] tracking-widest uppercase mb-4 lg:mb-6" style="background: rgba(208, 167, 255, 0.3); color: #500092;">The Soul</div>
            <p class="font-body text-sm lg:text-base leading-relaxed mb-6 lg:mb-8" style="color: rgba(54, 59, 16, 0.6);">The constitutional and civilizational framework that defines principles, governance, and stewardship of the network through commons-based coordination.</p>
          </div>
          <ul class="space-y-2 font-body text-xs lg:text-sm mb-6" style="color: rgba(54, 59, 16, 0.7);">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #8e00fd;">check</span>Polycentric Governance</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #8e00fd;">check</span>Multi-Capital Value</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm" style="color: #8e00fd;">check</span>Commons Stewardship</li>
          </ul>
          <a href="#common" class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase font-bold" style="color: #8e00fd;">
            Connect <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Core Functions Section -->
    <section id="ecosystem" class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12" style="background: rgba(244, 247, 206, 0.3);">
      <div class="max-w-[1920px] mx-auto">
        <div class="text-center mb-12 lg:mb-20">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4" style="background: rgba(0, 116, 58, 0.1); color: #00743a;">Core Infrastructure</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4 lg:mb-6" style="color: #363b10;">Digital Coordination Platform</h2>
          <p class="font-body text-base lg:text-lg max-w-2xl mx-auto" style="color: rgba(54, 59, 16, 0.6);">Gaia Hub functions as the digital operating system of the ecosystem - a meta-platform for network coordination and evolution.</p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-8">
          {coreFunctions.map((func, index) => (
            <div class="group p-6 lg:p-8 rounded-xl ethereal-shadow hover:translate-y-[-4px] transition-all duration-300" style="background: white;">
              <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform" style="background: rgba(255, 215, 9, 0.15);">
                <span class="material-symbols-outlined text-xl lg:text-2xl" style="color: #776300;">{func.icon}</span>
              </div>
              <h3 class="font-headline text-lg lg:text-xl font-bold mb-2 lg:mb-3" style="color: #363b10;">{func.title}</h3>
              <p class="font-body text-sm lg:text-base leading-relaxed" style="color: rgba(54, 59, 16, 0.6);">{func.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Gaia Impact Fund Section -->
    <section id="capital" class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div>
            <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 lg:mb-6" style="background: rgba(119, 99, 0, 0.1); color: #776300;">Provision & Development</span>
            <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold tracking-tight mb-4 lg:mb-6" style="color: #363b10;">Gaia Impact Fund</h2>
            <p class="font-body text-base lg:text-lg leading-relaxed mb-6 lg:mb-8" style="color: rgba(54, 59, 16, 0.7);">
              The primary strategic fund designed to mobilize, coordinate, and deploy capital toward regenerative initiatives at global, bioregional, and local levels.
            </p>
            <div class="space-y-4 mb-6 lg:mb-8">
              <div class="flex items-start gap-3">
