---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../../config/site.config.ts';

// Importar componentes de skills
import { SEOHead, SchemaOrg } from '../../../../skills/community/seo-ai-citations/index.ts';
import { TestimonialsGrid } from '../../../../skills/community/testimonials/index.ts';
import { ContactForm } from '../../../../skills/community/contact-form/index.ts';

// Testimonios del ecosistema
const testimonials = [
  {
    name: "María González",
    role: "Coordinadora Bioregional",
    company: "EcoVillage Costa Rica",
    content: "Gaia Hub transformó cómo nuestra comunidad se conecta con el mundo. De estar aislados, ahora somos nodos activos de un ecosistema global regenerativo.",
    rating: 5,
    image: "/images/testimonial-1.jpg"
  },
  {
    name: "Carlos Rodríguez",
    role: "Director de Impacto",
    company: "Regen Foundation",
    content: "El sistema de matchmaking de Gaia GPS nos conectó con aliados estratégicos que ni sabíamos que existían. La inteligencia del ecosistema es real.",
    rating: 5,
    image: "/images/testimonial-2.jpg"
  },
  {
    name: "Ana Martínez",
    role: "Emprendedora Regenerativa",
    company: "Semillas del Futuro",
    content: "En Gaia Market encontramos no solo clientes, sino una comunidad que valora verdaderamente lo regenerativo. Las ventas crecieron 300% en 6 meses.",
    rating: 5,
    image: "/images/testimonial-3.jpg"
  }
];

// Métricas del ecosistema
const metrics = [
  { value: "150+", label: "Bioregiones Activas", icon: "public" },
  { value: "2.4K", label: "Proyectos Regenerativos", icon: "eco" },
  { value: "$12M", label: "Capital Desplegado", icon: "account_balance" },
  { value: "45K", label: "Miembros del Ecosistema", icon: "diversity_3" }
];

// Servicios/Core Functions de Gaia Hub
const coreFunctions = [
  {
    icon: "visibility",
    title: "Ecosystem Visibility",
    description: "Make the ecosystem visible through a living directory and global map of people, projects, communities, and territories."
  },
  {
    icon: "hub",
    title: "Intelligent Connections",
    description: "Enable intelligent connections via Gaia GPS - mapping skills, needs, capacities, affinities, and bioregions."
  },
  {
    icon: "groups",
    title: "Coordination Infrastructure",
    description: "Coordinate collaboration across distributed actors functioning as a living regenerative network."
  },
  {
    icon: "track_changes",
    title: "Contribution Tracking",
    description: "Track contributions and reputation through transparent on-chain and off-chain mechanisms."
  },
  {
    icon: "account_balance",
    title: "Governance Support",
    description: "Support decision-making and governance through polycentric councils, DAOs, and consensus tools."
  },
  {
    icon: "auto_awesome",
    title: "Evolution & Adaptation",
    description: "Evolve as a platform that learns, adapts, and grows with its community of stewards."
  }
];
---

<Layout title="Gaia Hub | Digital Coordination Platform">
  <Fragment slot="head">
    <SEOHead 
      title="Gaia Hub | Digital Coordination Platform for Regenerative Ecosystems"
      description="Gaia Hub is the digital operating system of the Gaia Ecosystem. A meta-platform for network coordination, matchmaking, and regenerative collaboration."
      keywords={["regenerative economy", "Gaia Hub", "commons", "bioregions", "impact fund", "regenerative marketplace", "coordination platform"]}
      ogImage="/og-image.jpg"
      canonicalUrl="https://gaiahub.co"
    />
    <SchemaOrg type={["Organization", "WebSite"]} />
  </Fragment>
  
  <main class="min-h-screen bg-background text-on-surface">
    
    <!-- Top Navigation Shell -->
    <nav class="sticky top-0 z-50 w-full px-6 lg:px-12 py-6 max-w-[1920px] mx-auto flex justify-between items-center bg-background/80 backdrop-blur-xl shadow-ethereal">
      <div class="text-2xl font-black tracking-tighter font-headline text-primary">Gaia Hub</div>
      <div class="hidden md:flex items-center gap-10">
        <a class="font-headline tracking-tight font-bold uppercase text-sm text-on-surface/60 hover:text-on-surface transition-colors" href="#intelligence">Intelligence</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm text-on-surface/60 hover:text-on-surface transition-colors" href="#market">Market</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm text-on-surface/60 hover:text-on-surface transition-colors" href="#commons">Commons</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm text-on-surface/60 hover:text-on-surface transition-colors" href="#capital">Capital</a>
        <a class="font-headline tracking-tight font-bold uppercase text-sm text-on-surface/60 hover:text-on-surface transition-colors" href="#incubation">Incubation</a>
      </div>
      <div class="flex items-center gap-4 lg:gap-6">
        <button class="material-symbols-outlined p-2 rounded-full transition-all hover:bg-primary-container/10 text-primary">search</button>
        <button class="hidden sm:block px-6 lg:px-8 py-3 rounded-full text-white font-headline text-xs tracking-widest uppercase hover:scale-[1.02] active:scale-95 transition-all shadow-ethereal bg-gradient-to-r from-primary to-primary-container text-on-primary-container font-bold">Connect Soul</button>
        <button class="sm:hidden material-symbols-outlined p-2 rounded-full text-primary">menu</button>
      </div>
    </nav>

    <!-- Hero Section: The Conduit of Light -->
    <section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-20 lg:pt-32 pb-16 px-6 overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
        <div class="absolute top-[-10%] right-[-5%] w-[400px] h-[400px] lg:w-[600px] lg:h-[600px] rounded-full blur-[120px] bg-primary-container"></div>
        <div class="absolute bottom-[0%] left-[-10%] w-[300px] h-[300px] lg:w-[500px] lg:h-[500px] rounded-full blur-[100px] bg-secondary-container"></div>
      </div>
      
      <div class="relative z-10 text-center max-w-5xl px-4">
        <span class="inline-block px-6 py-2 rounded-full font-semibold text-sm tracking-wide mb-8 font-label bg-secondary-container/40 text-on-secondary-container">
          Ethereal Conduit v2.0
        </span>
        
        <h1 class="font-headline text-4xl sm:text-5xl md:text-7xl lg:text-8xl xl:text-9xl font-black tracking-tighter leading-[0.9] mb-8 lg:mb-12 text-primary">
          The Digital <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-container">Nervous System</span>
        </h1>
        
        <p class="font-body text-lg sm:text-xl md:text-2xl mb-10 lg:mb-16 max-w-2xl mx-auto leading-relaxed text-on-surface/70">
          Harmonizing human intelligence with planetary vitality through an interconnected web of capital, commons, and market flows.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8">
          <a href="#ecosystem" class="bg-gradient-to-r from-primary to-primary-container text-on-primary-container px-10 lg:px-12 py-4 lg:py-5 rounded-full font-headline text-sm tracking-widest uppercase shadow-xl hover:scale-105 transition-all w-full sm:w-auto text-center font-bold">
            Enter the Portal
          </a>
          <a href="#triad" class="group flex items-center justify-center gap-3 font-headline text-sm tracking-widest uppercase text-primary font-bold">
            Explore Governance <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
          </a>
        </div>
      </div>
      
      <!-- Asymmetric Visual Element -->
      <div class="relative mt-16 lg:mt-32 w-full max-w-7xl px-4 sm:px-6">
        <div class="aspect-[21/9] rounded-xl lg:rounded-2xl overflow-hidden shadow-ethereal relative">
          <img 
            alt="Earth from space" 
            class="w-full h-full object-cover"
            src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent"></div>
          <div class="absolute bottom-6 left-6 lg:bottom-12 lg:left-12">
            <p class="font-headline text-white/90 text-lg lg:text-2xl font-bold drop-shadow-lg">A Living Regenerative Organism</p>
            <p class="font-body text-white/70 text-sm lg:text-base drop-shadow-md">Coordinating 150+ bioregions worldwide</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-12">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          {metrics.map((metric) => (
            <div class="text-center p-6 lg:p-8 rounded-2xl shadow-ethereal bg-white">
              <div class="w-12 h-12 lg:w-16 lg:h-16 rounded-full flex items-center justify-center mx-auto mb-4 bg-primary-container/20">
                <span class="material-symbols-outlined text-2xl lg:text-3xl text-primary">{metric.icon}</span>
              </div>
              <div class="font-headline text-3xl lg:text-5xl font-black tracking-tighter mb-2 text-primary">{metric.value}</div>
              <div class="font-body text-xs lg:text-sm uppercase tracking-widest text-on-surface/60">{metric.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Triad of Life Section -->
    <section id="triad" class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12 max-w-[1920px] mx-auto">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-12 lg:mb-24 gap-6 lg:gap-8">
        <div class="max-w-xl">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 bg-primary/10 text-primary">The Gaia Triad</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4 lg:mb-6 text-on-surface">The Triad of Life</h2>
          <p class="font-body text-base lg:text-lg text-on-surface/60">Our ecosystem functions as a biological entity, utilizing three core systems to process value, information, and wisdom.</p>
        </div>
        <div class="flex gap-2 lg:gap-4">
          <div class="w-12 lg:w-16 h-1 rounded-full bg-primary"></div>
          <div class="w-6 lg:w-8 h-1 rounded-full bg-primary/20"></div>
          <div class="w-6 lg:w-8 h-1 rounded-full bg-primary/20"></div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-12">
        <!-- Card 1: Gaia Hub (Nervous System) -->
        <div class="group relative rounded-xl lg:rounded-2xl p-6 lg:p-10 shadow-ethereal hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between bg-white">
          <div class="absolute top-0 right-0 p-6 lg:p-8">
            <span class="material-symbols-outlined text-3xl lg:text-4xl text-primary/20 group-hover:text-primary transition-colors">hub</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full flex items-center justify-center mb-6 lg:mb-10 group-hover:scale-110 transition-transform bg-primary-container/20">
              <span class="material-symbols-outlined text-2xl lg:text-3xl text-primary">network_intelligence</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl mb-3 lg:mb-4 text-on-surface">Gaia Hub</h3>
            <div class="inline-block px-3 lg:px-4 py-1 rounded-full font-bold text-[10px] tracking-widest uppercase mb-4 lg:mb-6 bg-secondary-container/30 text-on-secondary-container">The Nervous System</div>
            <p class="font-body text-sm lg:text-base leading-relaxed mb-6 lg:mb-8 text-on-surface/60">The digital coordination platform that makes the ecosystem visible, enables intelligent connections, and coordinates collaboration across distributed actors.</p>
          </div>
          <ul class="space-y-2 font-body text-xs lg:text-sm mb-6 text-on-surface/70">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-primary">check</span>Directory & Global Map</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-primary">check</span>Gaia GPS Matchmaking</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-primary">check</span>Contribution Tracking</li>
          </ul>
          <a href="#hub" class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase font-bold text-primary">
            Synchronize <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </a>
        </div>

        <!-- Card 2: Gaia Market (Circulatory) -->
        <div id="market" class="group relative rounded-xl lg:rounded-2xl p-6 lg:p-10 shadow-ethereal hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between bg-surface-container border border-primary/5">
          <div class="absolute top-0 right-0 p-6 lg:p-8">
            <span class="material-symbols-outlined text-3xl lg:text-4xl text-primary/20 group-hover:text-primary transition-colors">currency_exchange</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full flex items-center justify-center mb-6 lg:mb-10 group-hover:scale-110 transition-transform bg-primary/10">
              <span class="material-symbols-outlined text-2xl lg:text-3xl text-primary">storefront</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl mb-3 lg:mb-4 text-on-surface">Gaia Market</h3>
            <div class="inline-block px-3 lg:px-4 py-1 rounded-full font-bold text-[10px] tracking-widest uppercase mb-4 lg:mb-6 bg-primary-container/30 text-on-primary-container">Circulatory System</div>
            <p class="font-body text-sm lg:text-base leading-relaxed mb-6 lg:mb-8 text-on-surface/60">The regenerative marketplace where value is exchanged in alignment with regenerative principles - products, services, experiences, and knowledge.</p>
          </div>
          <ul class="space-y-2 font-body text-xs lg:text-sm mb-6 text-on-surface/70">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-primary">check</span>Regenerative Products</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-primary">check</span>Services & Experiences</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-primary">check</span>Knowledge & Courses</li>
          </ul>
          <a href="#marketplace" class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase font-bold text-primary">
            Exchange <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </a>
        </div>

        <!-- Card 3: The Commons (Soul) -->
        <div id="commons" class="group relative rounded-xl lg:rounded-2xl p-6 lg:p-10 shadow-ethereal hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between bg-surface-container-high">
          <div class="absolute top-0 right-0 p-6 lg:p-8">
            <span class="material-symbols-outlined text-3xl lg:text-4xl text-tertiary/20 group-hover:text-tertiary transition-colors">diversity_3</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full flex items-center justify-center mb-6 lg:mb-10 group-hover:scale-110 transition-transform bg-tertiary-container/20">
              <span class="material-symbols-outlined text-2xl lg:text-3xl text-tertiary">account_balance</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl mb-3 lg:mb-4 text-on-surface">Gaia Commons</h3>
            <div class="inline-block px-3 lg:px-4 py-1 rounded-full font-bold text-[10px] tracking-widest uppercase mb-4 lg:mb-6 bg-tertiary-container/30 text-on-tertiary-container">The Soul</div>
            <p class="font-body text-sm lg:text-base leading-relaxed mb-6 lg:mb-8 text-on-surface/60">The constitutional and civilizational framework that defines principles, governance, and stewardship of the network through commons-based coordination.</p>
          </div>
          <ul class="space-y-2 font-body text-xs lg:text-sm mb-6 text-on-surface/70">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-tertiary">check</span>Polycentric Governance</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-tertiary">check</span>Multi-Capital Value</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-tertiary">check</span>Commons Stewardship</li>
          </ul>
          <a href="#common" class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase font-bold text-tertiary">
            Connect <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Core Functions Section -->
    <section id="ecosystem" class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12 bg-surface-container/50">
      <div class="max-w-[1920px] mx-auto">
        <div class="text-center mb-12 lg:mb-20">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 bg-secondary/10 text-secondary">Core Infrastructure</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4 lg:mb-6 text-on-surface">Digital Coordination Platform</h2>
          <p class="font-body text-base lg:text-lg max-w-2xl mx-auto text-on-surface/60">Gaia Hub functions as the digital operating system of the ecosystem - a meta-platform for network coordination and evolution.</p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-8">
          {coreFunctions.map((func) => (
            <div class="group p-6 lg:p-8 rounded-xl shadow-ethereal hover:translate-y-[-4px] transition-all duration-300 bg-white">
              <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform bg-primary-container/15">
                <span class="material-symbols-outlined text-xl lg:text-2xl text-primary">{func.icon}</span>
              </div>
              <h3 class="font-headline text-lg lg:text-xl font-bold mb-2 lg:mb-3 text-on-surface">{func.title}</h3>
              <p class="font-body text-sm lg:text-base leading-relaxed text-on-surface/60">{func.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Gaia Impact Fund Section -->
    <section id="capital" class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div>
            <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 lg:mb-6 bg-primary/10 text-primary">Provision & Development</span>
            <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold tracking-tight mb-4 lg:mb-6 text-on-surface">Gaia Impact Fund</h2>
            <p class="font-body text-base lg:text-lg leading-relaxed mb-6 lg:mb-8 text-on-surface/70">
              The primary strategic fund designed to mobilize, coordinate, and deploy capital toward regenerative initiatives at global, bioregional, and local levels.
            </p>
            <div class="space-y-4 mb-6 lg:mb-8">
              <div class="flex items-start gap-3">
                <span class="material-symbols-outlined mt-1 text-primary">account_balance</span>
                <div>
                  <h4 class="font-headline font-bold text-sm lg:text-base text-on-surface">Capital Aggregator</h4>
                  <p class="font-body text-xs lg:text-sm text-on-surface/60">Gathers resources from investment, donations, marketplace flows, and tokens</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="material-symbols-outlined mt-1 text-primary">route</span>
                <div>
                  <h4 class="font-headline font-bold text-sm lg:text-base text-on-surface">Financial Orchestrator</h4>
                  <p class="font-body text-xs lg:text-sm text-on-surface/60">Strategically allocates capital across specialized funds</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="material-symbols-outlined mt-1 text-primary">rocket_launch</span>
                <div>
                  <h4 class="font-headline font-bold text-sm lg:text-base text-on-surface">Impact Accelerator</h4>
                  <p class="font-body text-xs lg:text-sm text-on-surface/60">Prioritizes high-regenerative-potential initiatives</p>
                </div>
              </div>
            </div>
            <a href="#fund" class="inline-flex items-center gap-2 bg-gradient-to-r from-primary to-primary-container text-on-primary-container px-6 lg:px-8 py-3 lg:py-4 rounded-full font-headline text-xs lg:text-sm tracking-widest uppercase shadow-lg hover:scale-105 transition-all font-bold">
              Explore Fund <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
          <div class="relative">
            <div class="aspect-square rounded-2xl lg:rounded-3xl overflow-hidden shadow-ethereal">
              <img 
                src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2070&auto=format&fit=crop" 
                alt="Impact visualization" 
                class="w-full h-full object-cover"
              />
            </div>
            <!-- Floating stats cards -->
            <div class="absolute -bottom-4 -left-4 lg:-bottom-8 lg:-left-8 bg-white rounded-xl lg:rounded-2xl p-4 lg:p-6 shadow-ethereal">
              <div class="font-headline text-2xl lg:text-4xl font-black text-primary">$12M+</div>
              <div class="font-body text-xs lg:text-sm uppercase tracking-wider text-on-surface/60">Capital Deployed</div>
            </div>
            <div class="absolute -top-4 -right-4 lg:-top-8 lg:-right-8 rounded-xl lg:rounded-2xl p-4 lg:p-6 shadow-ethereal bg-secondary-container/30">
              <div class="font-headline text-2xl lg:text-4xl font-black text-on-secondary-container">85+</div>
              <div class="font-body text-xs lg:text-sm uppercase tracking-wider text-on-surface/60">Projects Funded</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bento Grid: Ecosystem Pulse -->
    <section class="py-20 lg:py-32 px-4 sm:px-6 lg:px-12 bg-surface-container/50">
      <div class="max-w-[1920px] mx-auto">
        <div class="text-center mb-12 lg:mb-16">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 bg-secondary/10 text-secondary">Live Ecosystem</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-on-surface">Ecosystem Pulse</h2>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 lg:grid-rows-2 gap-4 lg:gap-8 h-auto lg:h-[800px]">
          <!-- Large Card -->
          <div class="sm:col-span-2 lg:col-span-2 lg:row-span-2 bg-white rounded-xl lg:rounded-2xl p-6 lg:p-12 shadow-ethereal relative overflow-hidden flex flex-col justify-end min-h-[300px] lg:min-h-0">
            <div class="absolute top-0 left-0 w-full h-full">
              <img 
