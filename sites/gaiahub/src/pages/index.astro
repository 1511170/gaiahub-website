---
import Layout from '../layouts/Layout.astro';
import Navigation from '@site/components/Navigation.astro';
import Footer from '@site/components/Footer.astro';
import GaiaContactForm from '@site/components/GaiaContactForm.astro';
import { t } from '@site/i18n';
import { getCollection } from 'astro:content';

const locale = 'en';
const i18n = t(locale);

// Fetch testimonials and latest blog posts
const allTestimonials = (await getCollection('testimonials'))
  .filter(t => t.data.published)
  .sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());

const latestPosts = (await getCollection('blog'))
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout 
  title={i18n.home.meta_title}
  description={i18n.home.meta_description}
  image="/images/hero-banner.webp"
  keywords={["regenerative economy", "Gaia", "commons", "bioregions", "regenerative marketplace", "coordination platform", "ecosistema regenerativo"]}
  schemaType={["Organization", "WebSite"]}
>
  
  <Navigation locale={locale} activePage="home" />

  <main>
    <!-- Hero Section: Full-bleed background image with centered content -->
    <section class="relative pt-28 pb-16 lg:pb-20 px-6 lg:px-[5.5rem] overflow-hidden min-h-[92vh] flex items-center bg-cover bg-center" style="background-image: url('/images/hero-banner.webp');">
      <div class="absolute inset-0 bg-black/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-black/40"></div>
      <div class="max-w-[1618px] mx-auto w-full relative z-10">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-block px-4 py-1.5 rounded-full bg-white/15 backdrop-blur-sm border border-white/20 text-white text-xs font-bold tracking-widest uppercase mb-6 gsap-fade-up">
            {i18n.home.hero_badge}
          </div>
          <h1 class="hero-title font-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[0.95] tracking-tighter mb-6 drop-shadow-[0_4px_20px_rgba(0,0,0,0.6)]">
            {i18n.home.hero_title.split('regenerates')[0]}<span class="text-primary italic">regenerates</span>.
          </h1>
          <p class="hero-subtitle text-lg md:text-xl text-white max-w-xl mx-auto font-light leading-relaxed mb-8 drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">
            {i18n.home.hero_subtitle}
          </p>
          <div class="hero-cta flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#triada" class="solar-gradient px-8 py-4 rounded-full text-white font-headline font-bold text-base hover:opacity-90 transition-all scale-95 active:scale-90 shadow-xl text-center">
              {i18n.home.cta_discover}
            </a>
            <a href="/confederation/" class="bg-white/20 backdrop-blur-md border border-white/30 px-8 py-4 rounded-full text-white font-headline font-bold text-base hover:bg-white/30 transition-all text-center shadow-lg">
              {i18n.home.cta_join}
            </a>
          </div>
          <!-- Newsletter -->
          <div class="mt-8 max-w-md mx-auto gsap-fade-up">
            <p class="text-xs font-bold text-white/80 uppercase tracking-wider mb-2 drop-shadow-md">{i18n.home.newsletter_title}</p>
            <form class="flex gap-2" onsubmit="event.preventDefault(); alert('Thanks for subscribing!');">
              <input 
                type="email" 
                placeholder={i18n.home.newsletter_placeholder}
                class="flex-1 px-4 py-2.5 rounded-full bg-white/15 backdrop-blur-md border border-white/30 text-white placeholder:text-white/60 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 text-sm shadow-lg"
                required
              />
              <button 
                type="submit"
                class="solar-gradient px-5 py-2.5 rounded-full text-white font-headline font-bold text-sm hover:opacity-90 transition-all shadow-lg"
              >
                {i18n.home.newsletter_button}
              </button>
            </form>
          </div>
          <!-- Functional Search -->
          <div class="mt-10 max-w-xl mx-auto relative">
            <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-white/60 drop-shadow">search</span>
            <input 
              id="home-search"
              type="text" 
              placeholder={i18n.home.search_placeholder}
              class="w-full pl-14 pr-6 py-4 rounded-full bg-white/15 backdrop-blur-md border border-white/30 text-white placeholder:text-white/60 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 text-lg shadow-xl"
            />
            <span class="absolute right-5 top-1/2 -translate-y-1/2 text-xs font-bold text-primary uppercase tracking-wider hidden sm:block drop-shadow">{i18n.home.search_title}</span>
          </div>
          <p id="search-no-results" class="hidden mt-4 text-sm text-white/80 drop-shadow"></p>
        </div>
      </div>
    </section>

    <!-- Concept Section: Full-bleed image with text overlay -->
    <section class="relative py-[7rem] lg:py-[10rem] px-6 lg:px-[5.5rem] overflow-hidden gsap-fade-up">
      <div class="absolute inset-0 -z-10">
        <img src="/images/concept-bg.webp" class="w-full h-full object-cover" alt="Regenerative landscape"  loading="eager" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-r from-on-surface/90 via-on-surface/75 to-on-surface/50"></div>
      </div>
      <div class="max-w-[1618px] mx-auto relative z-10">
        <h2 class="font-headline text-4xl md:text-5xl lg:text-7xl font-black text-white leading-tight max-w-4xl mb-6 drop-shadow-lg">
          {i18n.home.concept_title}
        </h2>
        <p class="text-xl md:text-2xl text-white/85 leading-relaxed max-w-2xl drop-shadow-md">
          {i18n.home.concept_subtitle}
        </p>
      </div>
    </section>

    <!-- Concept Cards Section -->
    <section class="py-[5.5rem] px-6 lg:px-[5.5rem] bg-surface-container-low gsap-fade-up">
      <div class="max-w-[1618px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 gsap-stagger">
          <a href="/commons/" class="relative aspect-[4/3] rounded-xl overflow-hidden ethereal-shadow group block">
            <img src="/images/concept-regen.webp" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Regeneration"  loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 to-on-surface/20"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <span class="material-symbols-outlined text-4xl text-primary-container mb-2" style="font-variation-settings: 'FILL' 1;">eco</span>
              <h4 class="font-headline font-bold uppercase tracking-tight text-white">{i18n.home.concept_regeneration}</h4>
            </div>
          </a>
          <a href="/hub/" class="relative aspect-[4/3] rounded-xl overflow-hidden ethereal-shadow group block">
            <img src="/images/concept-coord.webp" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Coordination"  loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 to-on-surface/20"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <span class="material-symbols-outlined text-4xl text-primary-container mb-2" style="font-variation-settings: 'FILL' 1;">hub</span>
              <h4 class="font-headline font-bold uppercase tracking-tight text-white">{i18n.home.concept_coordination}</h4>
            </div>
          </a>
          <a href="/confederation/" class="relative aspect-[4/3] rounded-xl overflow-hidden ethereal-shadow group block">
            <img src="/images/concept-collab.webp" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Collaboration"  loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 to-on-surface/20"></div>
            <div class="absolute bottom-0 left-0 p-6">
              <span class="material-symbols-outlined text-4xl text-primary-container mb-2" style="font-variation-settings: 'FILL' 1;">diversity_3</span>
              <h4 class="font-headline font-bold uppercase tracking-tight text-white">Collaboration</h4>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- The Triad: La Triada -->
    <section id="triada" class="py-[5.5rem] px-6 lg:px-[5.5rem]">
      <div class="max-w-[1618px] mx-auto">
        <div class="text-center mb-24 gsap-fade-up">
          <h2 class="font-headline text-4xl md:text-5xl lg:text-7xl font-black uppercase tracking-tighter mb-4">{i18n.home.triad_title}</h2>
          <div class="h-1 w-24 bg-primary mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 gsap-stagger">
          <!-- Gaia Commons -->
          <div class="group relative p-10 lg:p-12 rounded-xl transition-all hover:-translate-y-4 block overflow-hidden" style="background-image: url('/images/triad-commons.webp'); background-size: cover; background-position: center;">
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/60"></div>
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="absolute top-0 right-0 p-8 text-white/10 font-black text-6xl font-headline">01</div>
            <div class="relative">
              <span class="material-symbols-outlined text-5xl text-white mb-8 drop-shadow-lg" style="font-variation-settings: 'FILL' 1;">favorite</span>
              <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 text-white drop-shadow-md">{i18n.home.triad_commons_title}</h3>
              <p class="text-white/90 font-headline font-bold uppercase tracking-widest text-sm mb-2">{i18n.home.triad_commons_system}</p>
              <p class="text-white/80 leading-relaxed mb-6">{i18n.home.triad_commons_desc_new}</p>
              <div class="flex flex-wrap gap-3 mb-6">
                <a href="/impact-fund/" class="relative z-20 inline-flex items-center gap-1 px-4 py-2 rounded-full bg-white/15 text-white text-xs font-bold uppercase tracking-wider hover:bg-white/25 transition-colors backdrop-blur-sm">
                  {i18n.home.triad_commons_fund_link}
                </a>
                <a href="/impact-hub/" class="relative z-20 inline-flex items-center gap-1 px-4 py-2 rounded-full bg-white/15 text-white text-xs font-bold uppercase tracking-wider hover:bg-white/25 transition-colors backdrop-blur-sm">
                  {i18n.home.triad_commons_hub_link}
                </a>
              </div>
              <span class="inline-flex items-center gap-2 font-headline font-bold uppercase text-sm group-hover:gap-4 transition-all text-white">
                {i18n.home.triad_commons_cta} <span class="material-symbols-outlined">arrow_forward</span>
              </span>
            </div>
            <a href="/commons/" class="absolute inset-0 z-10" aria-label={i18n.home.triad_commons_title}></a>
          </div>
          <!-- Gaia Hub -->
          <div class="group relative p-10 lg:p-12 rounded-xl transition-all hover:-translate-y-4 block overflow-hidden" style="background-image: url('/images/triad-hub.webp'); background-size: cover; background-position: center;">
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/60"></div>
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="absolute top-0 right-0 p-8 text-white/10 font-black text-6xl font-headline">02</div>
            <div class="relative">
              <span class="material-symbols-outlined text-5xl text-white mb-8 drop-shadow-lg" style="font-variation-settings: 'FILL' 1;">network_node</span>
              <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 text-white drop-shadow-md">{i18n.home.triad_hub_title}</h3>
              <p class="text-white/90 font-headline font-bold uppercase tracking-widest text-sm mb-6">{i18n.home.triad_hub_subtitle}</p>
              <p class="text-white/80 leading-relaxed mb-8">{i18n.home.triad_hub_desc}</p>
              <span class="inline-flex items-center gap-2 font-headline font-bold uppercase text-sm group-hover:gap-4 transition-all text-white">
                {i18n.home.triad_hub_cta} <span class="material-symbols-outlined">arrow_forward</span>
              </span>
            </div>
            <a href="/hub/" class="absolute inset-0 z-10" aria-label={i18n.home.triad_hub_title}></a>
          </div>
          <!-- Gaia Market -->
          <div class="group relative p-10 lg:p-12 rounded-xl transition-all hover:-translate-y-4 block overflow-hidden" style="background-image: url('/images/triad-market.webp'); background-size: cover; background-position: center;">
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/60"></div>
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="absolute top-0 right-0 p-8 text-white/10 font-black text-6xl font-headline">03</div>
            <div class="relative">
              <span class="material-symbols-outlined text-5xl text-white mb-8 drop-shadow-lg" style="font-variation-settings: 'FILL' 1;">storefront</span>
              <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 text-white drop-shadow-md">{i18n.home.triad_market_title}</h3>
              <p class="text-white/90 font-headline font-bold uppercase tracking-widest text-sm mb-6">{i18n.home.triad_market_subtitle}</p>
              <p class="text-white/80 leading-relaxed mb-8">{i18n.home.triad_market_desc}</p>
              <span class="inline-flex items-center gap-2 font-headline font-bold uppercase text-sm group-hover:gap-4 transition-all text-white">
                {i18n.home.triad_market_cta} <span class="material-symbols-outlined">arrow_forward</span>
              </span>
            </div>
            <a href="/market/" class="absolute inset-0 z-10" aria-label={i18n.home.triad_market_title}></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Flow Section: Cómo funciona -->
    <section id="como-funciona" class="relative py-[5.5rem] lg:py-[7rem] px-6 lg:px-[5.5rem] bg-surface gsap-fade-up overflow-hidden">
      <div class="absolute inset-0 -z-0 opacity-5">
        <img src="/images/flow-bg.webp" class="w-full h-full object-cover" alt=""  loading="lazy" decoding="async" />
      </div>
      <div class="max-w-[1618px] mx-auto">
        <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-black text-center mb-20">{i18n.home.how_title}</h2>
        <div class="relative flex flex-col md:flex-row justify-between items-center gap-6 lg:gap-4 px-4 lg:px-8 gsap-stagger">
          <!-- Invisible Connector Line for Web -->
          <div class="hidden md:block absolute top-1/2 left-0 w-full h-px border-t border-dashed border-primary-container -z-0"></div>
          
          <div class="relative z-10 flex flex-col items-center text-center max-w-[180px]">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-lg mb-6 border-2 border-primary-container">
              <span class="material-symbols-outlined text-primary">shopping_bag</span>
            </div>
            <h4 class="font-headline font-bold text-sm uppercase mb-2">{i18n.home.how_market}</h4>
          </div>
          
          <span class="material-symbols-outlined text-primary-container md:rotate-0 rotate-90">arrow_forward_ios</span>
          
          <div class="relative z-10 flex flex-col items-center text-center max-w-[180px]">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-lg mb-6 border-2 border-primary-container">
              <span class="material-symbols-outlined text-primary">volunteer_activism</span>
            </div>
            <h4 class="font-headline font-bold text-sm uppercase mb-2">{i18n.home.how_contribution}</h4>
          </div>
          
          <span class="material-symbols-outlined text-primary-container md:rotate-0 rotate-90">arrow_forward_ios</span>
          
          <div class="relative z-10 flex flex-col items-center text-center max-w-[180px]">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-lg mb-6 border-2 border-primary-container">
              <span class="material-symbols-outlined text-primary">trending_up</span>
            </div>
            <h4 class="font-headline font-bold text-sm uppercase mb-2">{i18n.home.how_capital}</h4>
          </div>
          
          <span class="material-symbols-outlined text-primary-container md:rotate-0 rotate-90">arrow_forward_ios</span>
          
          <div class="relative z-10 flex flex-col items-center text-center max-w-[180px]">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-lg mb-6 border-2 border-primary-container">
              <span class="material-symbols-outlined text-primary">public</span>
            </div>
            <h4 class="font-headline font-bold text-sm uppercase mb-2">{i18n.home.how_impact}</h4>
          </div>
          
          <span class="material-symbols-outlined text-primary-container md:rotate-0 rotate-90">all_inclusive</span>
          
          <div class="relative z-10 flex flex-col items-center text-center max-w-[100px]">
            <div class="w-16 h-16 rounded-full solar-gradient flex items-center justify-center shadow-xl mb-6">
              <span class="material-symbols-outlined text-white">auto_awesome</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    {allTestimonials.length > 0 && (
      <section class="py-[5.5rem] px-6 lg:px-[5.5rem] bg-surface-container-low gsap-fade-up">
        <div class="max-w-[1618px] mx-auto">
          <div class="text-center mb-16">
            <div class="inline-block px-4 py-1.5 rounded-full bg-primary-container text-on-primary-container text-xs font-bold tracking-widest uppercase mb-6">
              Voices from the Ecosystem
            </div>
            <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-black text-on-surface tracking-tighter mb-4">
              What Stewards Say
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 gsap-stagger">
            {allTestimonials.map((t) => (
              <article class="bg-white rounded-xl p-6 shadow-sm border border-outline/5 h-full flex flex-col" itemscope itemtype="https://schema.org/Review">
                <div class="flex gap-1 mb-4" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
                  <meta itemprop="ratingValue" content={t.data.rating.toString()} />
                  <meta itemprop="bestRating" content="5" />
                  {Array(5).fill(0).map((_, i) => (
                    <svg class={`w-5 h-5 ${i < t.data.rating ? 'text-yellow-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <blockquote class="flex-1">
                  <p class="text-on-surface/70 italic mb-4 text-sm leading-relaxed" itemprop="reviewBody">"{t.data.quote}"</p>
                </blockquote>
                <footer class="flex items-center gap-3 mt-4 pt-4 border-t border-outline/10">
                  {t.data.image && (
                    <img src={t.data.image} alt={t.data.author} class="w-10 h-10 rounded-full object-cover" itemprop="image" loading="lazy" decoding="async" />
                  )}
                  <div>
                    <cite class="not-italic font-headline font-bold text-on-surface text-sm" itemprop="author" itemscope itemtype="https://schema.org/Person">
                      <span itemprop="name">{t.data.author}</span>
                    </cite>
                    {t.data.company && (
                      <p class="text-xs text-on-surface/50">{t.data.company}</p>
                    )}
                  </div>
                </footer>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Ecosystem Gallery Section -->
    <section class="py-[5.5rem] px-6 lg:px-[5.5rem] bg-surface-container gsap-fade-up">
      <div class="max-w-[1618px] mx-auto">
        <div class="text-center mb-16">
          <div class="inline-block px-4 py-1.5 rounded-full bg-secondary-container text-on-secondary-container text-xs font-bold tracking-widest uppercase mb-6">
            Ecosystem in Action
          </div>
          <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-black text-on-surface tracking-tighter">
            Regenerative Futures
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 gsap-stagger">
          <a href="/bioregions/" class="aspect-[3/4] rounded-xl overflow-hidden ethereal-shadow block">
            <img src="/images/bioregions-hero.webp" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" alt="Bioregions"  loading="lazy" decoding="async" />
          </a>
          <a href="/ecohabitats/" class="aspect-[3/4] rounded-xl overflow-hidden ethereal-shadow mt-8 md:mt-0 block">
            <img src="/images/ecohabitats-hero.webp" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" alt="EcoHabitats"  loading="lazy" decoding="async" />
          </a>
          <a href="/academy/" class="aspect-[3/4] rounded-xl overflow-hidden ethereal-shadow block">
            <img src="/images/academy-hero.webp" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" alt="Academy"  loading="lazy" decoding="async" />
          </a>
        </div>
      </div>
    </section>

    <!-- Latest Blog Posts Section -->
    {latestPosts.length > 0 && (
      <section class="py-[5.5rem] px-6 lg:px-[5.5rem] bg-surface gsap-fade-up">
        <div class="max-w-[1618px] mx-auto">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16">
            <div>
              <div class="inline-block px-4 py-1.5 rounded-full bg-secondary-container text-on-secondary-container text-xs font-bold tracking-widest uppercase mb-6">
                Latest Insights
              </div>
              <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-black text-on-surface tracking-tighter">
                From the Blog
              </h2>
            </div>
            <a href="/blog/" class="mt-6 md:mt-0 inline-flex items-center gap-2 font-headline font-bold text-primary uppercase tracking-wider text-sm hover:gap-4 transition-all">
              View all posts <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 gsap-stagger">
            {latestPosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="group block bg-surface-container-low rounded-xl overflow-hidden hover:-translate-y-2 transition-all duration-300 ethereal-shadow">
                <div class="aspect-video bg-surface-container-high overflow-hidden">
                  {post.data.image ? (
