---
import Layout from '../layouts/Layout.astro';
import siteConfig from '../../config/site.config.ts';

// Importar componentes de skills
import { SEOHead, SchemaOrg } from '../../../../skills/community/seo-ai-citations/index.ts';
import { ContactForm } from '../../../../skills/community/contact-form/index.ts';

// Testimonios del ecosistema - Stewards
const stewards = [
  {
    name: "María González",
    role: "Coordinadora Bioregional",
    organization: "EcoVillage Costa Rica",
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop&crop=face",
    quote: "Gaia Hub transformó completamente cómo nuestra comunidad se conecta con el mundo. De estar aislados en nuestra región, ahora somos nodos activos de un ecosistema global regenerativo. La plataforma nos permitió encontrar aliados, recursos y visibilidad que ni sabíamos que existían.",
    rating: 5
  },
  {
    name: "Carlos Rodríguez",
    role: "Director de Impacto",
    organization: "Regen Foundation",
    avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&crop=face",
    quote: "El sistema de matchmaking de Gaia GPS es simplemente extraordinario. Nos conectó con aliados estratégicos que ni sabíamos que existían, pero que compartían nuestra visión de regeneración. La inteligencia del ecosistema es real y funciona.",
    rating: 5
  },
  {
    name: "Ana Martínez",
    role: "Emprendedora Regenerativa",
    organization: "Semillas del Futuro",
    avatar: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&h=200&fit=crop&crop=face",
    quote: "En Gaia Market encontramos no solo clientes, sino una comunidad que valora verdaderamente lo regenerativo. Las ventas crecieron 300% en 6 meses, pero más importante: encontramos nuestra tribu, gente que entiende y apoya nuestro propósito.",
    rating: 5
  }
];

// Métricas del ecosistema
const metrics = [
  { value: "150+", label: "Bioregiones Activas", icon: "public" },
  { value: "2.4K", label: "Proyectos Regenerativos", icon: "eco" },
  { value: "$12M", label: "Capital Desplegado", icon: "account_balance" },
  { value: "45K", label: "Miembros del Ecosistema", icon: "diversity_3" }
];
---

<Layout title="Gaia Ecosystem | Home Portal">
  <Fragment slot="head">
    <SEOHead 
      title="Gaia Ecosystem | Home Portal"
      description="Gaia Hub is the digital operating system of the Gaia Ecosystem. A meta-platform for network coordination, matchmaking, and regenerative collaboration."
      keywords={["regenerative economy", "Gaia Hub", "commons", "bioregions", "impact fund", "regenerative marketplace", "coordination platform"]}
      ogImage="/og-image.jpg"
      canonicalUrl="https://gaiahub.co"
    />
    <SchemaOrg type={["Organization", "WebSite"]} />
  </Fragment>
  
  <!-- Top Navigation Shell -->
  <nav class="sticky top-0 z-50 w-full px-6 lg:px-12 py-6 max-w-[1920px] mx-auto flex justify-between items-center bg-[#fefee5]/80 backdrop-blur-xl shadow-[0_20px_40px_-15px_rgba(54,59,16,0.05)]">
    <div class="text-2xl font-black text-[#776300] tracking-tighter font-headline">Gaia Ecosystem</div>
    <div class="hidden md:flex items-center gap-10">
      <a class="font-headline tracking-tight font-bold uppercase text-sm text-[#363b10]/60 hover:text-[#363b10] transition-colors" href="#">Intelligence</a>
      <a class="font-headline tracking-tight font-bold uppercase text-sm text-[#363b10]/60 hover:text-[#363b10] transition-colors" href="#">Market</a>
      <a class="font-headline tracking-tight font-bold uppercase text-sm text-[#363b10]/60 hover:text-[#363b10] transition-colors" href="#">Commons</a>
      <a class="font-headline tracking-tight font-bold uppercase text-sm text-[#363b10]/60 hover:text-[#363b10] transition-colors" href="#">Capital</a>
      <a class="font-headline tracking-tight font-bold uppercase text-sm text-[#363b10]/60 hover:text-[#363b10] transition-colors" href="#">Incubation</a>
    </div>
    <div class="flex items-center gap-6">
      <button class="material-symbols-outlined text-[#776300] hover:bg-[#ffd709]/10 p-2 rounded-full transition-all">search</button>
      <button class="bg-primary px-8 py-3 rounded-full text-white font-headline text-xs tracking-widest uppercase hover:scale-[1.02] active:scale-95 transition-all ethereal-shadow">Connect Soul</button>
    </div>
  </nav>
  
  <main class="relative">
    <!-- Hero Section: The Conduit of Light -->
    <section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-32 pb-16 px-6 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
        <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-primary-container rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[0%] left-[-10%] w-[500px] h-[500px] bg-secondary-container rounded-full blur-[100px]"></div>
      </div>
      <div class="relative z-10 text-center max-w-5xl">
        <span class="inline-block px-6 py-2 rounded-full bg-secondary-container/40 text-on-secondary-container font-semibold text-sm tracking-wide mb-8 font-label">
          Ethereal Conduit v2.0
        </span>
        <h1 class="font-headline text-5xl sm:text-6xl md:text-8xl lg:text-9xl text-primary font-black tracking-tighter leading-[0.9] mb-12">
          A Living <br/>
          <span class="text-transparent bg-clip-text solar-gradient">Regenerative Organism</span>
        </h1>
        <p class="font-body text-lg md:text-xl lg:text-2xl text-on-surface/70 max-w-2xl mx-auto leading-relaxed mb-16">
          Harmonizing human intelligence with planetary vitality through an interconnected web of capital, commons, and market flows.
        </p>
        <div class="flex flex-col md:flex-row items-center justify-center gap-8">
          <button class="solar-gradient text-white px-12 py-5 rounded-full font-headline text-sm tracking-widest uppercase shadow-xl hover:scale-105 transition-all">Enter the Portal</button>
          <button class="group flex items-center gap-3 font-headline text-sm tracking-widest uppercase text-primary font-bold">
            Explore Governance <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
          </button>
        </div>
      </div>
      <!-- Asymmetric Visual Element -->
      <div class="relative mt-32 w-full max-w-7xl px-6">
        <div class="aspect-[21/9] rounded-xl overflow-hidden ethereal-shadow relative">
          <img 
            alt="Earth from space" 
            class="w-full h-full object-cover" 
            src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent"></div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 lg:py-24 px-4 sm:px-6 lg:px-12">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          {metrics.map((metric) => (
            <div class="text-center p-6 lg:p-8 rounded-2xl shadow-ethereal bg-white">
              <div class="w-12 h-12 lg:w-16 lg:h-16 rounded-full flex items-center justify-center mx-auto mb-4 bg-primary-container/20">
                <span class="material-symbols-outlined text-2xl lg:text-3xl text-primary">{metric.icon}</span>
              </div>
              <div class="font-headline text-3xl lg:text-5xl font-black tracking-tighter mb-2 text-primary">{metric.value}</div>
              <div class="font-body text-xs lg:text-sm uppercase tracking-widest text-on-surface/60">{metric.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Triad of Life Section -->
    <section class="py-20 lg:py-32 px-6 lg:px-12 max-w-[1920px] mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 lg:mb-24 gap-8">
        <div class="max-w-xl">
          <h2 class="font-headline text-4xl lg:text-5xl text-on-surface font-extrabold tracking-tight mb-6">The Triad of Life</h2>
          <p class="font-body text-lg text-on-surface/60">Our ecosystem functions as a biological entity, utilizing three core systems to process value, information, and wisdom.</p>
        </div>
        <div class="flex gap-4">
          <div class="w-16 h-1 bg-primary"></div>
          <div class="w-8 h-1 bg-primary/20"></div>
          <div class="w-8 h-1 bg-primary/20"></div>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Card 1: Gaia Hub (Soul) -->
        <div class="group relative bg-surface-container-lowest rounded-xl p-8 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between">
          <div class="absolute top-0 right-0 p-8">
            <span class="material-symbols-outlined text-4xl text-primary/20 group-hover:text-primary transition-colors" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-primary-container/20 flex items-center justify-center mb-8 lg:mb-10 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-2xl lg:text-3xl text-primary">psychology</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl text-on-surface mb-4">Gaia Hub</h3>
            <div class="inline-block px-4 py-1 rounded-full bg-secondary-container/30 text-on-secondary-container font-bold text-[10px] tracking-widest uppercase mb-6">The Soul</div>
            <p class="font-body text-on-surface/60 leading-relaxed mb-8">Centralized intelligence governing the identity and core directive of the planetary organism.</p>
          </div>
          <button class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase text-primary font-bold">
            Synchronize <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </button>
        </div>
        <!-- Card 2: Gaia Market (Circulatory) -->
        <div class="group relative bg-surface-container rounded-xl p-8 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between border border-primary/5">
          <div class="absolute top-0 right-0 p-8">
            <span class="material-symbols-outlined text-4xl text-primary/20 group-hover:text-primary transition-colors" style="font-variation-settings: 'FILL' 1;">currency_exchange</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-primary/10 flex items-center justify-center mb-8 lg:mb-10 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-2xl lg:text-3xl text-primary">account_balance_wallet</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl text-on-surface mb-4">Gaia Market</h3>
            <div class="inline-block px-4 py-1 rounded-full bg-primary-container/30 text-on-primary-container font-bold text-[10px] tracking-widest uppercase mb-6">Circulatory</div>
            <p class="font-body text-on-surface/60 leading-relaxed mb-8">Facilitating the rhythmic flow of resources and energy across the global network.</p>
          </div>
          <button class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase text-primary font-bold">
            Exchange <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </button>
        </div>
        <!-- Card 3: The Commons (Nervous System) -->
        <div class="group relative bg-surface-container-high rounded-xl p-8 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500 overflow-hidden min-h-[450px] lg:min-h-[500px] flex flex-col justify-between">
          <div class="absolute top-0 right-0 p-8">
            <span class="material-symbols-outlined text-4xl text-tertiary/20 group-hover:text-tertiary transition-colors" style="font-variation-settings: 'FILL' 1;">hub</span>
          </div>
          <div>
            <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-tertiary-container/20 flex items-center justify-center mb-8 lg:mb-10 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-2xl lg:text-3xl text-tertiary">diversity_3</span>
            </div>
            <h3 class="font-headline text-2xl lg:text-3xl text-on-surface mb-4">The Commons</h3>
            <div class="inline-block px-4 py-1 rounded-full bg-tertiary-container/30 text-on-tertiary-container font-bold text-[10px] tracking-widest uppercase mb-6">Nervous System</div>
            <p class="font-body text-on-surface/60 leading-relaxed mb-8">The distributed awareness that connects every node in a shared field of collective wisdom.</p>
          </div>
          <button class="group/btn flex items-center gap-2 font-headline text-xs tracking-widest uppercase text-tertiary font-bold">
            Connect <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">chevron_right</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Bento Grid: Ecosystem Pulse -->
    <section class="py-20 lg:py-32 px-6 lg:px-12 bg-surface-container-low/50">
      <div class="max-w-[1920px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-8 h-auto md:h-[800px]">
          <div class="md:col-span-2 md:row-span-2 bg-white rounded-xl p-8 lg:p-12 ethereal-shadow relative overflow-hidden flex flex-col justify-end">
            <div class="absolute top-0 left-0 w-full h-full">
              <img 
                alt="Forest view" 
                class="w-full h-full object-cover grayscale opacity-20 hover:grayscale-0 hover:opacity-100 transition-all duration-1000" 
                src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?q=80&w=2026&auto=format&fit=crop"
              />
            </div>
            <div class="relative z-10">
              <h4 class="font-headline text-3xl lg:text-4xl text-primary font-black mb-4">Regenerative Capital</h4>
              <p class="font-body text-base lg:text-lg text-on-surface/70 mb-8 max-w-sm">Investing in the protocols that heal the planet and empower the people.</p>
              <button class="bg-primary text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-all">
                <span class="material-symbols-outlined">trending_up</span>
              </button>
            </div>
          </div>
          <div class="md:col-span-2 bg-surface-container-highest rounded-xl p-8 lg:p-10 flex flex-col justify-center relative overflow-hidden">
            <div class="absolute right-0 top-0 h-full w-1/2 opacity-20 bg-gradient-to-l from-primary to-transparent"></div>
            <div class="flex items-center gap-6 mb-4">
              <span class="material-symbols-outlined text-primary text-4xl">eco</span>
              <span class="font-headline text-xl lg:text-2xl font-bold">Biomass Index</span>
            </div>
            <div class="text-4xl lg:text-5xl font-black text-primary font-headline tracking-tighter">+12.4%</div>
            <div class="font-body text-sm text-on-surface/60 mt-2 uppercase tracking-widest">Global Recovery Rate</div>
          </div>
          <div class="bg-secondary-container/20 rounded-xl p-8 lg:p-10 flex flex-col items-center justify-center text-center">
            <div class="w-14 h-14 lg:w-16 lg:h-16 rounded-full bg-white flex items-center justify-center mb-6 shadow-sm">
              <span class="material-symbols-outlined text-secondary text-2xl">waves</span>
            </div>
            <div class="font-headline text-lg lg:text-xl font-bold mb-2">Ocean Flows</div>
            <div class="font-body text-on-surface/60 text-sm">Real-time salinity data</div>
          </div>
          <div class="bg-primary-container/10 rounded-xl p-8 lg:p-10 flex flex-col items-center justify-center text-center">
            <div class="w-14 h-14 lg:w-16 lg:h-16 rounded-full bg-white flex items-center justify-center mb-6 shadow-sm">
              <span class="material-symbols-outlined text-primary text-2xl">solar_power</span>
            </div>
            <div class="font-headline text-lg lg:text-xl font-bold mb-2">Solar Yield</div>
            <div class="font-body text-on-surface/60 text-sm">Grid autonomy reached</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stewards of the Ecosystem - Testimonios Mejorados -->
    <section class="py-20 lg:py-32 px-6 lg:px-12 bg-gradient-to-br from-surface-container/50 to-surface-container-high/50">
      <div class="max-w-[1920px] mx-auto">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 bg-secondary/10 text-secondary">Community Voices</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-on-surface">Stewards of the Ecosystem</h2>
          <p class="font-body text-lg text-on-surface/60 mt-4 max-w-2xl mx-auto">Stories from the regenerative network</p>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {stewards.map((steward, index) => (
            <div class="group relative bg-white rounded-2xl p-8 lg:p-10 ethereal-shadow hover:translate-y-[-8px] transition-all duration-500">
              <!-- Quote Icon -->
              <div class="absolute top-8 right-8 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-6xl text-primary">format_quote</span>
              </div>
              
              <!-- Avatar and Info -->
              <div class="flex items-center gap-4 mb-6">
                <div class="relative">
                  <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full overflow-hidden border-3 border-primary/20 shadow-lg">
                    <img 
                      src={steward.avatar} 
                      alt={steward.name}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    />
                  </div>
                  <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-primary-container rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-[10px] text-primary">verified</span>
                  </div>
                </div>
                <div>
                  <h3 class="font-headline text-lg font-bold text-on-surface">{steward.name}</h3>
                  <p class="font-body text-sm text-on-surface/60">{steward.role}</p>
                  <p class="font-body text-xs text-primary font-medium">{steward.organization}</p>
                </div>
              </div>
              
              <!-- Rating -->
              <div class="flex gap-1 mb-6">
                {Array.from({ length: steward.rating }).map(() => (
                  <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                ))}
              </div>
              
              <!-- Quote -->
              <blockquote class="relative">
                <p class="font-body text-on-surface/70 leading-relaxed text-base italic">
                  "{steward.quote}"
                </p>
              </blockquote>
              
              <!-- Decorative Element -->
              <div class="mt-8 pt-6 border-t border-on-surface/10 flex items-center justify-between">
                <span class="font-body text-xs text-on-surface/40 uppercase tracking-widest">Steward</span>
                <div class="flex gap-2">
                  <span class="w-2 h-2 rounded-full bg-primary/20"></span>
                  <span class="w-2 h-2 rounded-full bg-secondary/20"></span>
                  <span class="w-2 h-2 rounded-full bg-tertiary/20"></span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 lg:py-32 px-6 lg:px-12 bg-primary">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-black text-white mb-4 lg:mb-6">
          Ready to join the<br/>regenerative organism?
        </h2>
        <p class="font-body text-base lg:text-xl text-white/80 mb-8 lg:mb-12 max-w-2xl mx-auto">
          Connect your project, community, or bioregion to a global network of stewards building a regenerative civilization.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#join" class="px-8 lg:px-12 py-4 lg:py-5 bg-white rounded-full font-headline text-sm tracking-widest uppercase shadow-lg hover:scale-105 transition-all text-primary font-bold">
            Join the Ecosystem
          </a>
          <a href="mailto:hello@gaiahub.co" class="px-8 lg:px-12 py-4 lg:py-5 rounded-full font-headline text-sm tracking-widest uppercase border border-white/30 text-white hover:bg-white/10 transition-all">
            Contact Stewards
          </a>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20 lg:py-32 px-6 lg:px-12 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 lg:mb-12">
          <span class="inline-block px-4 py-1 rounded-full font-medium text-xs tracking-widest uppercase mb-4 bg-primary/10 text-primary">Get in Touch</span>
          <h2 class="font-headline text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3 lg:mb-4 text-on-surface">Connect with Gaia</h2>
          <p class="font-body text-base lg:text-lg text-on-surface/60">
            Whether you're a project seeking incubation, an investor looking for impact, or a bioregion ready to coordinate - we're here to connect.
          </p>
        </div>
        <div class="rounded-2xl lg:rounded-3xl p-6 lg:p-12 ethereal-shadow bg-surface-container/30">
          <ContactForm 
            title="Start the Conversation"
            subtitle="Tell us about your project, needs, or vision for regeneration."
            submitLabel="Send Message"
            showPhone={true}
            showCompany={true}
          />
        </div>
      </div>
    </section>
  </main>

  <!-- Dynamic Side Navigation (Floating Portal) -->
  <aside class="hidden lg:flex fixed left-6 top-1/2 -translate-y-1/2 w-20 glass-panel rounded-full flex-col items-center py-10 gap-10 shadow-2xl z-40 border border-white/40">
    <div class="w-12 h-12 rounded-full bg-primary-container flex items-center justify-center shadow-md">
      <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">public</span>
    </div>
    <div class="flex flex-col gap-8">
      <button class="material-symbols-outlined text-on-surface/40 hover:text-primary transition-all text-2xl">explore</button>
      <button class="material-symbols-outlined text-primary transition-all text-2xl" style="font-variation-settings: 'FILL' 1;">favorite</button>
      <button class="material-symbols-outlined text-on-surface/40 hover:text-primary transition-all text-2xl">waves</button>
    </div>
    <div class="mt-auto">
      <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-primary/20">
        <img 
          alt="User" 
          class="w-full h-full object-cover" 
          src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=100&auto=format&fit=crop"
        />
      </div>
    </div>
  </aside>

  <!-- Footer -->
  <footer class="w-full py-16 lg:py-24 px-6 lg:px-12 bg-surface-container-lowest border-t border-[#363b10]/5 flex flex-col items-center justify-center space-y-8 lg:space-y-12">
    <div class="flex flex-wrap justify-center gap-6 lg:gap-12">
      <a class="font-body text-xs tracking-[0.2em] uppercase font-bold text-[#363b10]/40 hover:text-[#363b10] transition-colors" href="#">Intelligence</a>
