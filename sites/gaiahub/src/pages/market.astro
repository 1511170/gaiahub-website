---
import Layout from '../layouts/Layout.astro';
import Navigation from '@site/components/Navigation.astro';
import Footer from '@site/components/Footer.astro';
import { t } from '@site/i18n';

const locale = 'en';
const i18n = t(locale);
---

<Layout 
  title={i18n.market.meta_title}
  description={i18n.market.meta_description}
  keywords={["Gaia Market", "regenerative marketplace", "regenerative economy", "sustainable products", "regenerative services", "conscious experiences"]}
  schemaType={["WebPage", "Organization"]}
>
  
  <Navigation locale={locale} activePage="market" />

  <main class="pt-32">
    <!-- Hero Section -->
    <section class="px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto mb-32">
      <div class="grid grid-cols-1 lg:grid-cols-[1.618fr_1fr] gap-12 lg:gap-16 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center px-4 py-2 rounded-full bg-secondary-container/50 text-secondary font-semibold text-xs tracking-widest uppercase">
            {i18n.market.hero_badge}
          </div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black font-headline text-on-surface leading-[1.05] tracking-tighter">
            Gaia Market
          </h1>
          <p class="text-2xl md:text-3xl font-headline font-bold text-on-surface/80 tracking-tight">
            The regenerative marketplace
          </p>
          <p class="text-xl md:text-2xl text-on-surface/60 max-w-xl leading-relaxed font-light">
            The economic layer of the Gaia Ecosystem, where value is exchanged in alignment with regenerative principles.
          </p>
          <p class="text-lg text-on-surface/60 max-w-xl leading-relaxed font-light">
            It is more than a marketplace — it is a platform for regenerative economic activity, connecting producers, creators, service providers, and communities.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <a href="/hub/" class="px-10 py-5 rounded-full solar-gradient text-white font-headline font-bold text-sm tracking-widest uppercase shadow-2xl hover:translate-y-[-4px] transition-all text-center">
              Explore the Ecosystem
            </a>
            <a href="/commons/" class="px-10 py-5 rounded-full bg-surface-container-highest text-on-surface font-headline font-bold text-sm tracking-widest uppercase hover:bg-surface-container transition-all text-center">
              Discover Commons
            </a>
          </div>
        </div>
        <div class="relative group">
          <div class="absolute -inset-4 bg-primary-container/20 blur-3xl rounded-full group-hover:bg-primary-container/30 transition-all duration-700"></div>
          <img 
            alt="Regenerative marketplace" 
            class="relative w-full aspect-[4/5] object-cover rounded-xl shadow-2xl transform transition-transform duration-700 group-hover:scale-[1.02]" 
            src="https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?q=80&w=2070&auto=format&fit=crop"
          />
        </div>
      </div>
    </section>

    <!-- Core Functions -->
    <section class="bg-surface-container py-24 lg:py-32 px-6 lg:px-[5.5rem]">
      <div class="max-w-[1618px] mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-black text-on-surface tracking-tighter mb-4">Core Functions</h2>
          <div class="h-1 w-32 bg-primary rounded-full mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
          <a href="/hub/" class="block bg-white rounded-2xl p-8 lg:p-10 shadow-sm border border-outline/5 hover:-translate-y-2 hover:shadow-lg transition-all duration-300 group">
            <div class="w-14 h-14 rounded-xl bg-primary-container flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
              <span class="material-symbols-outlined text-3xl text-primary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">sync_alt</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface mb-3">Enable exchange</h3>
            <p class="text-on-surface/60 leading-relaxed">Exchange of goods and services between actors in the regenerative ecosystem.</p>
          </a>
          <a href="/hub/" class="block bg-white rounded-2xl p-8 lg:p-10 shadow-sm border border-outline/5 hover:-translate-y-2 hover:shadow-lg transition-all duration-300 group">
            <div class="w-14 h-14 rounded-xl bg-secondary-container flex items-center justify-center mb-6 group-hover:bg-secondary transition-colors duration-300">
              <span class="material-symbols-outlined text-3xl text-secondary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">visibility</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface mb-3">Provide visibility</h3>
            <p class="text-on-surface/60 leading-relaxed">Visibility to regenerative initiatives that are transforming the world.</p>
          </a>
          <a href="/impact-fund/" class="block bg-white rounded-2xl p-8 lg:p-10 shadow-sm border border-outline/5 hover:-translate-y-2 hover:shadow-lg transition-all duration-300 group">
            <div class="w-14 h-14 rounded-xl bg-tertiary-container flex items-center justify-center mb-6 group-hover:bg-tertiary transition-colors duration-300">
              <span class="material-symbols-outlined text-3xl text-tertiary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">account_balance</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface mb-3">Generate revenue</h3>
            <p class="text-on-surface/60 leading-relaxed">Revenue for the ecosystem that is reinvested in regenerative projects.</p>
          </a>
          <a href="/bioregions/" class="block bg-white rounded-2xl p-8 lg:p-10 shadow-sm border border-outline/5 hover:-translate-y-2 hover:shadow-lg transition-all duration-300 group">
            <div class="w-14 h-14 rounded-xl bg-primary-container flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
              <span class="material-symbols-outlined text-3xl text-primary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">nature_people</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface mb-3">Support livelihoods</h3>
            <p class="text-on-surface/60 leading-relaxed">Livelihoods aligned with regeneration for people and communities.</p>
          </a>
        </div>
      </div>
    </section>

    <!-- What Can Be Exchanged -->
    <section class="py-24 lg:py-32 px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto">
      <div class="mb-16 lg:mb-20">
        <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-black text-on-surface tracking-tighter mb-4">What Can Be Exchanged</h2>
        <div class="h-1 w-32 bg-primary rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8 items-stretch">
        <!-- Products -->
        <a href="/hub/" class="flex flex-col bg-surface-container rounded-2xl p-6 lg:p-8 border border-outline/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-primary-container flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
              <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">local_mall</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface">Products</h3>
          </div>
          <ul class="space-y-2 text-on-surface/70 text-sm">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Regenerative food (e.g., cacao, superfoods)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Natural health and wellness products</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Artisan goods</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Materials, crafts and accessories</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Regenerative tools and technologies</span>
            </li>
          </ul>
        </a>

        <!-- Services -->
        <a href="/academy/" class="flex flex-col bg-surface-container rounded-2xl p-6 lg:p-8 border border-outline/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-secondary-container flex items-center justify-center group-hover:bg-secondary transition-colors duration-300">
              <span class="material-symbols-outlined text-xl text-secondary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">handshake</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface">Services</h3>
          </div>
          <ul class="space-y-2 text-on-surface/70 text-sm">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-secondary text-xs mt-0.5">check_circle</span>
              <span>Holistic Health, Healing, Coaching, Mindfulness</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-secondary text-xs mt-0.5">check_circle</span>
              <span>Ecosystem and permaculture design</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-secondary text-xs mt-0.5">check_circle</span>
              <span>Consulting and facilitation</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-secondary text-xs mt-0.5">check_circle</span>
              <span>Digital services (design, dev, marketing, AI)</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-secondary text-xs mt-0.5">check_circle</span>
              <span>Education and training</span>
            </li>
          </ul>
        </a>

        <!-- Experiences -->
        <a href="/ecohabitats/" class="flex flex-col bg-surface-container rounded-2xl p-6 lg:p-8 border border-outline/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-tertiary-container flex items-center justify-center group-hover:bg-tertiary transition-colors duration-300">
              <span class="material-symbols-outlined text-xl text-tertiary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">travel_explore</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface">Experiences</h3>
          </div>
          <ul class="space-y-2 text-on-surface/70 text-sm">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-tertiary text-xs mt-0.5">check_circle</span>
              <span>Retreats</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-tertiary text-xs mt-0.5">check_circle</span>
              <span>Workshops</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-tertiary text-xs mt-0.5">check_circle</span>
              <span>Cultural events</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-tertiary text-xs mt-0.5">check_circle</span>
              <span>Conscious tourism</span>
            </li>
          </ul>
        </a>

        <!-- Knowledge -->
        <a href="/academy/" class="flex flex-col bg-surface-container rounded-2xl p-6 lg:p-8 border border-outline/5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-primary-container flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
              <span class="material-symbols-outlined text-xl text-primary group-hover:text-white transition-colors duration-300" style="font-variation-settings: 'FILL' 1;">menu_book</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-surface">Knowledge</h3>
          </div>
          <ul class="space-y-2 text-on-surface/70 text-sm">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Courses</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Certifications</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Research</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-xs mt-0.5">check_circle</span>
              <span>Methodologies</span>
            </li>
          </ul>
        </a>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="comunidad" class="py-24 lg:py-40 px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto text-center">
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-black font-headline tracking-tighter mb-8 lg:mb-12 leading-none">
        Connect with the regenerative marketplace
      </h2>
      <div class="flex flex-col sm:flex-row justify-center gap-4 lg:gap-8 mt-12 lg:mt-16">
        <a href="https://whatsapp.com/channel/0029VbCY4kLIiRozv7gGVN3L" target="_blank" rel="noopener noreferrer" class="px-8 lg:px-10 py-4 lg:py-5 rounded-full bg-[#25D366] text-white font-headline font-black text-base tracking-widest uppercase shadow-2xl hover:scale-105 transition-all text-center inline-flex items-center justify-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Join on WhatsApp
        </a>
        <a href="https://t.me/+1x_EVaVp-lEwN2I8" target="_blank" rel="noopener noreferrer" class="px-8 lg:px-10 py-4 lg:py-5 rounded-full bg-[#0088cc] text-white font-headline font-black text-base tracking-widest uppercase shadow-2xl hover:scale-105 transition-all text-center inline-flex items-center justify-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Join on Telegram
        </a>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Layout>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .ethereal-shadow {
    box-shadow: 0 40px 60px -5px rgba(54, 59, 16, 0.06);
  }
</style>
