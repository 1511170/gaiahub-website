---
import Layout from '../layouts/Layout.astro';
import Navigation from '@site/components/Navigation.astro';
import Footer from '@site/components/Footer.astro';
import { t } from '@site/i18n';

const locale = 'en';
const i18n = t(locale);
---

<Layout 
  title={i18n.impact_hub.meta_title}
  description={i18n.impact_hub.meta_description}
  image="/images/triad-hub.webp"
  keywords={["Gaia Impact Hub", "orquestación de impacto", "regenerative finance", "tokenización", "facilitación", "ecosistemas locales"]}
  schemaType={["WebPage", "Organization"]}
>
  
  <Navigation locale={locale} activePage="impact-hub" />

  <main class="pt-32">
    <!-- Hero Section -->
    <section class="px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto mb-32 relative">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 z-10">
          <span class="inline-block py-2 px-4 rounded-full bg-secondary-container text-on-secondary-container font-headline font-bold text-xs tracking-widest uppercase mb-8">
            {i18n.impact_hub.hero_badge}
          </span>
          <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-black text-on-surface leading-[0.9] tracking-tighter mb-8 uppercase">
            {i18n.impact_hub.hero_title}
          </h1>
          <p class="font-body text-xl md:text-2xl text-on-surface/70 max-w-xl leading-relaxed mb-12">
            {i18n.impact_hub.hero_subtitle}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/confederation/" class="solar-gradient text-white px-10 py-5 rounded-xl font-headline font-extrabold uppercase tracking-wider text-sm hover:translate-y-[-4px] transition-all">
              {i18n.impact_hub.cta_partner}
            </a>
            <a href="#comunidad" class="bg-surface-container-highest text-on-surface px-10 py-5 rounded-xl font-headline font-extrabold uppercase tracking-wider text-sm hover:translate-y-[-4px] transition-all">
              {i18n.impact_hub.cta_donate}
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative">
          <div class="aspect-[1/1.618] rounded-xl overflow-hidden shadow-2xl relative">
            <img 
              class="w-full h-full object-cover" 
              alt="Cosmic network of golden light" 
              src="/images/impact/cosmic-network.webp"
             loading="eager" fetchpriority="high" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"></div>
          </div>
          <!-- Decorative Glass Floating Card -->
          <div class="absolute -bottom-10 -left-10 glass-panel p-8 rounded-lg shadow-xl max-w-xs border border-white/40 hidden lg:block">
            <span class="material-symbols-outlined text-primary text-4xl mb-4">auto_awesome</span>
            <p class="text-sm font-bold uppercase font-headline tracking-tighter mb-2">{i18n.impact_hub.model_title}</p>
            <p class="text-xs text-on-surface/70 leading-relaxed">{i18n.impact_hub.model_step1_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Statement -->
    <section class="bg-surface-container-low py-24 lg:py-32 px-6 lg:px-[5.5rem]">
      <div class="max-w-[1618px] mx-auto flex flex-col items-center text-center">
        <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-black text-on-surface mb-8 uppercase tracking-tighter">{i18n.impact_hub.model_title}</h2>
        <p class="font-body text-2xl md:text-3xl text-on-surface/70 max-w-4xl leading-relaxed italic">
          "{i18n.impact_hub.model_step1} <span class="text-primary font-bold">{i18n.impact_hub.model_step2}</span>. {i18n.impact_hub.model_step3}"
        </p>
        <div class="mt-16 lg:mt-20 w-full grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
          <div class="bg-white p-10 lg:p-12 rounded-xl text-left border border-outline/10">
            <div class="text-primary text-5xl font-headline font-black mb-4">01</div>
            <h4 class="font-headline font-bold text-xl mb-4">{i18n.impact_hub.model_step1}</h4>
            <p class="text-on-surface/60 text-sm leading-relaxed">{i18n.impact_hub.model_step1_desc}</p>
          </div>
          <div class="bg-white p-10 lg:p-12 rounded-xl text-left border border-outline/10 lg:translate-y-8">
            <div class="text-primary text-5xl font-headline font-black mb-4">02</div>
            <h4 class="font-headline font-bold text-xl mb-4">{i18n.impact_hub.model_step2}</h4>
            <p class="text-on-surface/60 text-sm leading-relaxed">{i18n.impact_hub.model_step2_desc}</p>
          </div>
          <div class="bg-white p-10 lg:p-12 rounded-xl text-left border border-outline/10">
            <div class="text-primary text-5xl font-headline font-black mb-4">03</div>
            <h4 class="font-headline font-bold text-xl mb-4">{i18n.impact_hub.model_step3}</h4>
            <p class="text-on-surface/60 text-sm leading-relaxed">{i18n.impact_hub.model_step3_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Methodology: The Alchemist's Path -->
    <section class="py-24 lg:py-32 px-6 lg:px-[5.5rem] max-w-[1618px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-black mb-12 uppercase tracking-tighter">Orchestration Methodology</h2>
          <div class="space-y-12 lg:space-y-16">
            <div class="flex gap-6 lg:gap-8 group">
              <div class="flex-shrink-0 w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-primary transition-colors duration-500">
                <span class="material-symbols-outlined text-3xl group-hover:text-white">visibility</span>
              </div>
              <div>
                <h3 class="font-headline font-bold text-xl lg:text-2xl mb-2">{i18n.impact_hub.model_step1}</h3>
                <p class="text-on-surface/70 leading-relaxed">{i18n.impact_hub.model_step1_desc}</p>
              </div>
            </div>
            <div class="flex gap-6 lg:gap-8 group">
              <div class="flex-shrink-0 w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-tertiary transition-colors duration-500">
                <span class="material-symbols-outlined text-3xl group-hover:text-white">token</span>
              </div>
              <div>
                <h3 class="font-headline font-bold text-xl lg:text-2xl mb-2">{i18n.impact_hub.model_step2}</h3>
                <p class="text-on-surface/70 leading-relaxed">{i18n.impact_hub.model_step2_desc}</p>
              </div>
            </div>
            <div class="flex gap-6 lg:gap-8 group">
              <div class="flex-shrink-0 w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-secondary transition-colors duration-500">
                <span class="material-symbols-outlined text-3xl group-hover:text-white">groups</span>
              </div>
              <div>
                <h3 class="font-headline font-bold text-xl lg:text-2xl mb-2">{i18n.impact_hub.model_step3}</h3>
                <p class="text-on-surface/70 leading-relaxed">{i18n.impact_hub.model_step3_desc}</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative aspect-square">
          <div class="absolute inset-0 bg-primary/5 rounded-full blur-[100px]"></div>
          <div class="relative z-10 w-full h-full flex items-center justify-center">
            <img 
              class="w-full h-full object-cover rounded-2xl shadow-2xl" 
              alt="Global impact orchestration" 
              src="/images/impact/mountain-mist.webp"
             loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </section>

    <!-- Ecosystem Section: Bento Grid -->
    <section class="bg-surface py-24 lg:py-32 px-6 lg:px-[5.5rem]">
      <div class="max-w-[1618px] mx-auto">
        <h2 class="font-headline text-4xl md:text-5xl font-black mb-16 text-center uppercase tracking-tighter">Ecosystem of Actors</h2>
        <div class="grid grid-cols-1 md:grid-cols-12 md:grid-rows-2 gap-6 lg:gap-8 auto-rows-[250px]">
          <!-- NGOs -->
          <a href="/commons/" class="md:col-span-4 md:row-span-1 bg-surface-container p-8 lg:p-10 rounded-xl flex flex-col justify-between hover:bg-surface-container-high hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group overflow-hidden relative">
            <div class="z-10">
              <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 uppercase">{i18n.impact_hub.actor_ngo}</h3>
              <p class="text-on-surface/70 text-sm">{i18n.impact_hub.actor_ngo_desc}</p>
            </div>
            <span class="material-symbols-outlined text-7xl text-primary/10 absolute -bottom-4 -right-4 group-hover:scale-110 transition-transform">volunteer_activism</span>
          </a>

          <!-- Startups -->
          <a href="/market/" class="md:col-span-8 md:row-span-1 bg-surface-container p-8 lg:p-10 rounded-xl flex flex-col lg:flex-row items-center gap-6 lg:gap-10 hover:bg-surface-container-high hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 group overflow-hidden">
            <div class="w-full lg:w-1/3 h-48 lg:h-full rounded-lg overflow-hidden flex-shrink-0">
              <img 
                class="w-full h-full object-cover" 
                alt="Modern office space" 
                src="/images/impact/modern-office.webp"
               loading="lazy" decoding="async" />
            </div>
            <div>
              <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 uppercase">{i18n.impact_hub.actor_startup}</h3>
              <p class="text-on-surface/70 text-sm max-w-md">{i18n.impact_hub.actor_startup_desc}</p>
            </div>
          </a>

          <!-- Cooperativas -->
          <a href="/commons/" class="md:col-span-5 md:row-span-1 bg-tertiary-container/20 p-8 lg:p-10 rounded-xl flex flex-col justify-center border border-tertiary/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500">
            <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 uppercase">{i18n.impact_hub.actor_coop}</h3>
            <p class="text-on-surface/70 text-sm">{i18n.impact_hub.actor_coop_desc}</p>
          </a>

          <!-- Comunidades -->
          <a href="/bioregions/" class="md:col-span-4 md:row-span-1 bg-secondary-container/20 p-8 lg:p-10 rounded-xl flex flex-col justify-end border border-secondary/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500">
            <h3 class="font-headline text-2xl lg:text-3xl font-bold mb-4 uppercase">{i18n.impact_hub.actor_community}</h3>
            <p class="text-on-surface/70 text-sm">{i18n.impact_hub.actor_community_desc}</p>
          </a>

          <!-- Empresas -->
          <a href="/market/" class="md:col-span-3 md:row-span-1 bg-surface-container-highest p-8 lg:p-10 rounded-xl flex items-center justify-center text-center group hover:shadow-2xl hover:-translate-y-1 transition-all duration-500">
            <h3 class="font-headline text-xl lg:text-2xl font-black uppercase group-hover:tracking-[0.2em] transition-all duration-700">{i18n.impact_hub.actor_enterprise}</h3>
          </a>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="comunidad" class="py-24 lg:py-48 px-6 lg:px-[5.5rem] relative overflow-hidden bg-inverse-surface">
      <div class="absolute inset-0 opacity-20">
        <img 
          class="w-full h-full object-cover grayscale" 
          alt="Mountain peak at dawn" 
          src="/images/impact-fund/mountain-sunrise.webp"
         loading="lazy" decoding="async" />
      </div>
      <div class="max-w-[1618px] mx-auto relative z-10 text-center">
        <h2 class="font-headline text-4xl md:text-5xl lg:text-7xl font-black text-white mb-12 uppercase leading-none tracking-tighter">
          {i18n.impact_hub.hero_title}
        </h2>
        <div class="flex flex-col md:flex-row justify-center gap-4 lg:gap-8 mt-12 lg:mt-16">
          <a href="https://whatsapp.com/channel/0029VbCY4kLIiRozv7gGVN3L" target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white px-8 py-4 rounded-full font-headline font-bold text-base tracking-wider shadow-lg hover:scale-105 transition-all inline-flex items-center gap-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            WhatsApp
          </a>
          <a href="https://t.me/+1x_EVaVp-lEwN2I8" target="_blank" rel="noopener noreferrer" class="bg-[#0088cc] text-white px-8 py-4 rounded-full font-headline font-bold text-base tracking-wider shadow-lg hover:scale-105 transition-all inline-flex items-center gap-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            Telegram
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</Layout>

<style>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }
  .solar-gradient {
    background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
  }
  .glass-panel {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
</style>
