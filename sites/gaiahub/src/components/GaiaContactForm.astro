---
interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const isEn = locale === 'en';
---

<div class="bg-surface-container-low rounded-2xl p-8 lg:p-10 ethereal-shadow border border-outline/5">
  <h3 class="font-headline text-2xl font-bold text-on-surface mb-2">
    {isEn ? 'Get in Touch' : 'Contacto'}
  </h3>
  <p class="text-on-surface/60 mb-6">
    {isEn 
      ? 'Have a question or want to collaborate? Send us a message.' 
      : '¿Tienes una pregunta o quieres colaborar? Envíanos un mensaje.'}
  </p>
  
  <form 
    action="https://api.web3forms.com/submit" 
    method="POST" 
    class="space-y-5" 
    id="gaia-contact-form"
  >
    <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
    <input type="hidden" name="subject" value="New message from Gaia Hub" />
    <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
    
    <div class="grid md:grid-cols-2 gap-5">
      <div>
        <label for="contact-name" class="block text-sm font-bold text-on-surface/70 mb-2">
          {isEn ? 'Name' : 'Nombre'} <span class="text-red-500">*</span>
        </label>
        <input 
          type="text" 
          id="contact-name" 
          name="name" 
          required
          class="w-full px-4 py-3 rounded-xl bg-white border border-outline/20 text-on-surface placeholder:text-on-surface/40 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" 
          placeholder={isEn ? 'Your name' : 'Tu nombre'}
        />
      </div>
      <div>
        <label for="contact-email" class="block text-sm font-bold text-on-surface/70 mb-2">
          Email <span class="text-red-500">*</span>
        </label>
        <input 
          type="email" 
          id="contact-email" 
          name="email" 
          required
          class="w-full px-4 py-3 rounded-xl bg-white border border-outline/20 text-on-surface placeholder:text-on-surface/40 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" 
          placeholder="you@example.com"
        />
      </div>
    </div>
    
    <div>
      <label for="contact-subject" class="block text-sm font-bold text-on-surface/70 mb-2">
        {isEn ? 'Subject' : 'Asunto'}
      </label>
      <select 
        id="contact-subject" 
        name="subject_line"
        class="w-full px-4 py-3 rounded-xl bg-white border border-outline/20 text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all"
      >
        <option value="">{isEn ? 'Select a topic' : 'Selecciona un tema'}</option>
        <option value="collaboration">{isEn ? 'Collaboration' : 'Colaboración'}</option>
        <option value="investment">{isEn ? 'Investment' : 'Inversión'}</option>
        <option value="membership">{isEn ? 'Membership' : 'Membresía'}</option>
        <option value="media">{isEn ? 'Media & Press' : 'Prensa'}</option>
        <option value="other">{isEn ? 'Other' : 'Otro'}</option>
      </select>
    </div>
    
    <div>
      <label for="contact-message" class="block text-sm font-bold text-on-surface/70 mb-2">
        {isEn ? 'Message' : 'Mensaje'} <span class="text-red-500">*</span>
      </label>
      <textarea 
        id="contact-message" 
        name="message" 
        rows="4" 
        required
        class="w-full px-4 py-3 rounded-xl bg-white border border-outline/20 text-on-surface placeholder:text-on-surface/40 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all resize-y" 
        placeholder={isEn ? 'Tell us about your project or question...' : 'Cuéntanos sobre tu proyecto o pregunta...'}
      ></textarea>
    </div>
    
    <button 
      type="submit"
      class="w-full solar-gradient text-white font-headline font-bold py-4 rounded-xl shadow-lg hover:opacity-90 transition-all transform hover:-translate-y-1 active:translate-y-0 flex items-center justify-center gap-2"
    >
      {isEn ? 'Send Message' : 'Enviar Mensaje'}
      <span class="material-symbols-outlined">send</span>
    </button>
  </form>
  
  <!-- Success message -->
  <div id="contact-success" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-xl">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-green-600">check_circle</span>
      <div>
        <h4 class="font-headline font-bold text-green-900">
          {isEn ? 'Message sent!' : '¡Mensaje enviado!'}
        </h4>
        <p class="text-green-700 text-sm">
          {isEn ? "We'll get back to you soon." : 'Te responderemos pronto.'}
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('gaia-contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('contact-success');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    
    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      });
      
      const data = await response.json();
      
      if (data.success) {
        successMsg?.classList.remove('hidden');
        form.reset();
        setTimeout(() => {
          successMsg?.classList.add('hidden');
        }, 6000);
      } else {
        alert('Error sending message. Please try again.');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Error sending message. Please try again.');
    }
  });
</script>

<style>
  .ethereal-shadow {
    box-shadow: 0 40px 60px -5px rgba(54, 59, 16, 0.06);
  }
  .solar-gradient {
    background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
  }
</style>
