---
interface Props {
  title: string;
  subtitle?: string;
  ctaLabel: string;
  ctaHref: string;
  bgImage?: string;
  external?: boolean;
}
const { title, subtitle, ctaLabel, ctaHref, bgImage, external = false } = Astro.props;
---

<section class="relative py-24 lg:py-40 px-6 lg:px-[5.5rem] overflow-hidden gsap-fade-up">
  {bgImage && (
    <div class="absolute inset-0 -z-10">
      <img class="w-full h-full object-cover opacity-10" alt="" src={bgImage} />
    </div>
  )}
  <div class="max-w-[1618px] mx-auto text-center">
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-black font-headline tracking-tighter mb-6 lg:mb-8 text-on-surface">
      {title}
    </h2>
    {subtitle && (
      <p class="text-xl md:text-2xl text-on-surface/80 max-w-2xl mx-auto mb-12 font-light">{subtitle}</p>
    )}
    <div class="flex flex-col sm:flex-row justify-center gap-4 lg:gap-8 mt-12">
      <a 
        href={ctaHref} 
        target={external ? "_blank" : undefined}
        rel={external ? "noopener noreferrer" : undefined}
        class="px-12 lg:px-16 py-6 lg:py-8 rounded-full solar-gradient text-white font-headline font-black text-lg tracking-widest uppercase shadow-2xl hover:scale-105 transition-all"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .solar-gradient {
    background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
  }
</style>
