---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  image?: string;
  icon?: string;
}
const { badge, title, subtitle, ctaPrimary, ctaSecondary, image, icon } = Astro.props;
---

<section class="relative pt-32 pb-20 lg:pb-32 px-6 lg:px-[5.5rem] overflow-hidden">
  <div class="absolute top-0 right-0 w-full h-full -z-10 opacity-20 pointer-events-none">
    <div class="absolute top-[-10%] right-[-10%] w-[600px] h-[600px] rounded-full bg-primary-container blur-[120px]"></div>
  </div>
  <div class="max-w-[1618px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[1.618fr_1fr] gap-12 lg:gap-16 items-center">
      <div class="space-y-8 gsap-fade-up">
        {badge && (
          <span class="inline-block px-4 py-2 bg-secondary-container text-on-secondary-container rounded-full text-xs font-bold tracking-widest uppercase">
            {badge}
          </span>
        )}
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black font-headline text-on-surface leading-[1.05] tracking-tighter">
          {title}
        </h1>
        {subtitle && (
          <p class="text-xl md:text-2xl text-on-surface/70 max-w-xl leading-relaxed font-light">
            {subtitle}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          {ctaPrimary && (
            <a href={ctaPrimary.href} class="px-10 py-5 rounded-full solar-gradient text-white font-headline font-bold text-sm tracking-widest uppercase shadow-2xl hover:translate-y-[-4px] transition-all text-center">
              {ctaPrimary.label}
            </a>
          )}
          {ctaSecondary && (
            <a href={ctaSecondary.href} class="px-10 py-5 rounded-full bg-surface-container-highest text-on-surface font-headline font-bold text-sm tracking-widest uppercase hover:bg-surface-container transition-all text-center">
              {ctaSecondary.label}
            </a>
          )}
        </div>
      </div>
      <div class="relative group gsap-scale-in">
        <div class="absolute -inset-4 bg-primary-container/20 blur-3xl rounded-full group-hover:bg-primary-container/30 transition-all duration-700"></div>
        {image ? (
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl">
            <img src={image} alt={title} class="w-full h-full object-cover" />
          </div>
        ) : (
          <div class="relative aspect-[1/1.618] rounded-xl overflow-hidden shadow-2xl bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-8xl text-primary/30" style="font-variation-settings: 'FILL' 1;">{icon || 'auto_awesome'}</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .solar-gradient {
    background: linear-gradient(135deg, #776300 0%, #ffd709 100%);
  }
</style>
