---
interface Props {
  quote: string;
  author?: string;
  source?: string;
  variant?: 'default' | 'primary' | 'secondary';
}

const { quote, author, source, variant = 'default' } = Astro.props;

const variantClasses = {
  default: 'border-l-4 border-primary bg-gradient-to-r from-surface-container-low to-surface-container',
  primary: 'border-l-4 border-primary bg-primary-container/20',
  secondary: 'border-l-4 border-secondary bg-secondary-container/20',
};
---

<blockquote class={`my-8 p-6 md:p-8 rounded-r-xl ${variantClasses[variant]}`}>
  <div class="flex gap-4">
    <span class="material-symbols-outlined text-3xl text-primary/40 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">format_quote</span>
    <div>
      <p class="text-lg md:text-xl text-on-surface/90 leading-relaxed italic font-light">
        {quote}
      </p>
      {(author || source) && (
        <footer class="mt-4 flex items-center gap-2 text-sm text-on-surface/60">
          {author && <cite class="not-italic font-headline font-bold text-on-surface/80">{author}</cite>}
          {author && source && <span>—</span>}
          {source && <span>{source}</span>}
        </footer>
      )}
    </div>
  </div>
</blockquote>
