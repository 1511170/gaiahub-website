---
interface Props {
  title: string;
  body: string | string[];
  image?: string;
  icon?: string;
  reverse?: boolean;
  bg?: 'surface' | 'surface-container' | 'surface-container-low';
}
const { title, body, image, icon, reverse = false, bg = 'surface' } = Astro.props;
const bgClass = bg === 'surface-container' ? 'bg-surface-container' : bg === 'surface-container-low' ? 'bg-surface-container-low' : 'bg-surface';
const bodyLines = Array.isArray(body) ? body : [body];
---

<section class={`${bgClass} py-20 lg:py-28 px-6 lg:px-[5.5rem] gsap-fade-up`}>
  <div class="max-w-[1618px] mx-auto">
    <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center ${reverse ? 'lg:grid-flow-dense' : ''}`}>
      <div class={reverse ? 'lg:col-start-2' : ''}>
        <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-black text-on-surface mb-6 leading-tight tracking-tight">{title}</h2>
        <div class="space-y-4">
          {bodyLines.map(line => (
            <p class="text-lg text-on-surface/70 leading-relaxed">{line}</p>
          ))}
        </div>
      </div>
      <div class={reverse ? 'lg:col-start-1' : ''}>
        {image ? (
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl bg-surface-container-high">
            <img src={image} alt={title} class="w-full h-full object-cover" />
          </div>
        ) : (
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-9xl text-primary/20" style="font-variation-settings: 'FILL' 1;">{icon || 'eco'}</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
