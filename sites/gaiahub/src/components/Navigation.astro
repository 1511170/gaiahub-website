---
import { t } from '@site/i18n';

interface Props {
  locale?: string;
  activePage?: string;
}

const { locale = 'es', activePage = 'home' } = Astro.props;
const i18n = t(locale);
const isEn = locale === 'en';
const prefix = isEn ? '/en' : '';

const navItems = [
  { key: 'home', href: `${prefix}/`, label: i18n.nav.home },
  { key: 'hub', href: `${prefix}/hub`, label: i18n.nav.hub },
  { key: 'market', href: `${prefix}/market`, label: i18n.nav.market },
  { key: 'commons', href: `${prefix}/commons`, label: i18n.nav.commons },
];

const impactItems = [
  { href: `${prefix}/commons/impact-fund/`, label: i18n.nav.impact_fund },
  { href: `${prefix}/commons/impact-hub/`, label: i18n.nav.impact_hub },
];
---

<nav class="fixed top-0 w-full z-50 bg-[#fefee5]/90 backdrop-blur-xl shadow-[0_40px_60px_-5px_rgba(54,59,16,0.08)] border-b border-primary/5">
  <div class="flex justify-between items-center max-w-[1618px] mx-auto px-4 sm:px-6 lg:px-[5.5rem] h-20 md:h-24">
    <!-- Logo -->
    <a href={`${prefix}/`} class="text-2xl md:text-3xl font-black text-primary font-headline tracking-tight hover:scale-105 transition-transform">
      Gaia
    </a>
    
    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-8 lg:gap-12 font-headline tracking-tight font-bold uppercase text-sm">
      {navItems.map((item) => (
        <a 
          class={`relative py-2 transition-all duration-200 ${
            activePage === item.key 
              ? 'text-primary' 
              : 'text-on-surface/60 hover:text-on-surface'
          }`}
          href={item.href}
        >
          {item.label}
          {activePage === item.key && (
            <span class="absolute bottom-0 left-0 w-full h-0.5 bg-primary rounded-full"></span>
          )}
        </a>
      ))}
      
      <!-- Impact Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 py-2 text-on-surface/60 hover:text-on-surface transition-colors">
          {i18n.nav.impact}
          <span class="material-symbols-outlined text-sm transition-transform group-hover:rotate-180">expand_more</span>
        </button>
        <div class="absolute top-full right-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0">
          <div class="bg-white/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-outline/10 py-3 min-w-[200px]">
            {impactItems.map((item) => (
              <a 
                class="block px-5 py-3 text-on-surface/70 hover:text-primary hover:bg-primary/5 transition-colors text-sm font-medium" 
                href={item.href}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
    
    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center gap-4">
      <a 
        href="#comunidad" 
        class="bg-primary text-white px-6 py-3 rounded-full font-headline font-bold text-sm uppercase tracking-wider hover:shadow-lg hover:shadow-primary/25 hover:scale-105 active:scale-95 transition-all duration-200"
      >
        {i18n.nav.join}
      </a>
    </div>
    
    <!-- Mobile Menu Button -->
    <button 
      id="mobile-menu-btn" 
      class="md:hidden relative flex items-center justify-center w-11 h-11 rounded-xl bg-primary text-white shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 hover:scale-105 active:scale-95 transition-all duration-200"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span id="menu-icon-open" class="material-symbols-outlined text-xl">menu</span>
      <span id="menu-icon-close" class="material-symbols-outlined text-xl absolute inset-0 flex items-center justify-center opacity-0 rotate-90 transition-all duration-200">close</span>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay (Backdrop) -->
<div 
  id="mobile-backdrop" 
  class="fixed inset-0 bg-on-surface/40 backdrop-blur-sm z-40 opacity-0 invisible transition-all duration-300 md:hidden"
  aria-hidden="true"
></div>

<!-- Mobile Menu Drawer -->
<div 
  id="mobile-menu" 
  class="fixed top-0 right-0 h-full w-[85%] max-w-[320px] bg-[#fefee5] z-50 transform translate-x-full transition-transform duration-300 ease-out shadow-2xl md:hidden flex flex-col"
>
  <!-- Drawer Header -->
  <div class="flex items-center justify-between px-6 h-20 border-b border-outline/10">
    <span class="text-xl font-black text-primary font-headline tracking-tight">Gaia</span>
    <button 
      id="mobile-menu-close" 
      class="flex items-center justify-center w-10 h-10 rounded-xl bg-surface-container-high text-on-surface hover:bg-surface-container transition-colors"
      aria-label="Close menu"
    >
      <span class="material-symbols-outlined text-lg">close</span>
    </button>
  </div>
  
  <!-- Drawer Content -->
  <div class="flex-1 overflow-y-auto py-6 px-6">
    <div class="flex flex-col gap-1">
      {navItems.map((item) => (
        <a 
          class={`flex items-center px-4 py-4 rounded-xl font-headline font-bold text-lg transition-all duration-200 ${
            activePage === item.key 
              ? 'bg-primary text-white shadow-lg shadow-primary/20' 
              : 'text-on-surface hover:bg-surface-container'
          }`}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </div>
    
    <!-- Impact Section -->
    <div class="mt-6 pt-6 border-t border-outline/10">
      <span class="px-4 text-xs font-bold text-on-surface/40 uppercase tracking-wider">{i18n.nav.impact}</span>
      <div class="flex flex-col gap-1 mt-3">
        {impactItems.map((item) => (
          <a 
            class="flex items-center px-4 py-3 rounded-xl font-headline font-medium text-on-surface/80 hover:text-primary hover:bg-primary/5 transition-all duration-200"
            href={item.href}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
  
  <!-- Drawer Footer -->
  <div class="p-6 border-t border-outline/10">
    <a 
      href="#comunidad" 
      class="flex items-center justify-center w-full bg-primary text-white px-6 py-4 rounded-xl font-headline font-bold text-base uppercase tracking-wider shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:scale-[1.02] active:scale-95 transition-all duration-200"
    >
      {i18n.nav.join}
    </a>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileBackdrop = document.getElementById('mobile-backdrop');
  const menuCloseBtn = document.getElementById('mobile-menu-close');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  let isOpen = false;
  
  function openMenu() {
    isOpen = true;
    mobileMenu.classList.remove('translate-x-full');
    mobileMenu.classList.add('translate-x-0');
    mobileBackdrop.classList.remove('opacity-0', 'invisible');
    mobileBackdrop.classList.add('opacity-100', 'visible');
    menuIconOpen.classList.add('opacity-0', 'rotate-90');
    menuIconClose.classList.remove('opacity-0', 'rotate-90');
    document.body.style.overflow = 'hidden';
    menuBtn?.setAttribute('aria-expanded', 'true');
  }
  
  function closeMenu() {
    isOpen = false;
    mobileMenu.classList.add('translate-x-full');
    mobileMenu.classList.remove('translate-x-0');
    mobileBackdrop.classList.add('opacity-0', 'invisible');
    mobileBackdrop.classList.remove('opacity-100', 'visible');
    menuIconOpen.classList.remove('opacity-0', 'rotate-90');
    menuIconClose.classList.add('opacity-0', 'rotate-90');
    document.body.style.overflow = '';
    menuBtn?.setAttribute('aria-expanded', 'false');
  }
  
  menuBtn?.addEventListener('click', () => {
    if (isOpen) closeMenu();
    else openMenu();
  });
  
  menuCloseBtn?.addEventListener('click', closeMenu);
  mobileBackdrop?.addEventListener('click', closeMenu);
  
  // Close menu when clicking on links
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
  
  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
  
  // Close menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isOpen) closeMenu();
  });
</script>
